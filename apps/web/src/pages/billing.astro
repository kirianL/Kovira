---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Billing & Subscription — Kovira" activeTab="billing">
  <div class="relative z-5 flex-1 flex flex-col items-center px-6 py-10 max-w-[900px] mx-auto w-full max-[768px]:px-5 max-[768px]:py-6 overflow-y-auto max-[768px]:justify-start">
    
    <!-- Title Section -->
    <div class="w-full text-left mb-8">
      <h1 class="text-[28px] font-extrabold leading-tight tracking-[-0.025em] text-white mb-2">
        <span class="reveal-wrapper">
          <span class="reveal-text delay-1">Billing & Subscription</span>
        </span>
      </h1>
      <p class="text-xs text-white/60 animate-fade-in delay-2">
        Manage your subscription plan, update payment methods, and view your billing history.
      </p>
    </div>

    <div class="w-full flex flex-col gap-6 text-left animate-fade-in delay-3">
      
      <!-- Top Grid: Subscription & Payment Details -->
      <div class="grid grid-cols-2 gap-4 max-[768px]:grid-cols-1">
        
        <!-- Current Plan Card -->
        <div class="p-5 rounded-cards border border-white/10 bg-[#0d0e1e] flex flex-col justify-between">
          <div>
            <div class="text-[10px] font-bold text-ash uppercase tracking-wider mb-2">Current Plan</div>
            <div class="flex items-baseline gap-2 mb-2">
              <span class="text-xl font-bold text-white">Pro Plan</span>
              <span class="text-xs text-white/60">$29.00 / month</span>
            </div>
            <p class="text-xs text-white/50 leading-relaxed mb-4">
              Your next billing date is July 20, 2026. You are currently utilizing 4 of 5 team members.
            </p>
          </div>
          <div class="flex items-center gap-3 mt-2">
            <button class="bg-[#262626] text-white border border-white/15 px-4 py-2 rounded-buttons text-xs font-semibold hover:bg-[#171717] transition-all cursor-pointer btn-primary-shadow">
              Change Plan
            </button>
            <button class="bg-transparent text-white/50 border border-white/10 px-4 py-2 rounded-buttons text-xs font-medium hover:text-white hover:border-white/20 transition-all cursor-pointer">
              Cancel
            </button>
          </div>
        </div>

        <!-- Payment Method Card -->
        <div class="p-5 rounded-cards border border-white/10 bg-[#0d0e1e] flex flex-col justify-between">
          <div>
            <div class="text-[10px] font-bold text-ash uppercase tracking-wider mb-2">Payment Details</div>
            <div class="flex items-center gap-3 mb-3">
              <!-- Card Brand Logo Icon Container -->
              <div id="card-brand-logo-container" class="w-10 h-6 bg-white/5 rounded border border-white/10 flex items-center justify-center">
                <span id="active-card-brand-text" class="text-[9px] font-extrabold text-white tracking-widest">VISA</span>
              </div>
              <div>
                <div id="active-card-name" class="text-xs font-semibold text-white">Visa ending in 4242</div>
                <div id="active-card-expiry" class="text-[10px] text-white/50 font-mono">Expires 12/28</div>
              </div>
            </div>
            <p class="text-xs text-white/50 leading-relaxed mb-4">
              Charges appear as "KOVIRA* PLATFORM" on your statement.
            </p>
          </div>
          <div class="flex items-center gap-2 mt-2">
            <button id="open-payment-modal-btn" class="bg-transparent text-white/80 border border-white/10 px-4 py-2 rounded-buttons text-xs font-medium hover:text-white hover:border-white/20 transition-all cursor-pointer">
              Update Payment Method
            </button>
          </div>
        </div>

      </div>

      <!-- Bottom: Invoice History Table -->
      <div class="mt-4">
        <h2 class="text-sm font-bold text-white uppercase tracking-wider mb-4">Billing History</h2>
        
        <div class="w-full overflow-x-auto border border-white/10 rounded-cards bg-[#0d0e1e]">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="border-b border-white/10 text-[10px] text-ash uppercase font-bold tracking-wider">
                <th class="px-5 py-3">Invoice Number</th>
                <th class="px-5 py-3">Billing Date</th>
                <th class="px-5 py-3">Amount</th>
                <th class="px-5 py-3">Status</th>
                <th class="px-5 py-3 text-right">Action</th>
              </tr>
            </thead>
            <tbody class="text-xs text-white/80">
              <tr class="border-b border-white/5 hover:bg-white/5 transition-colors">
                <td class="px-5 py-3.5 font-mono text-white/90">RNY-05212026-0077</td>
                <td class="px-5 py-3.5">May 21, 2026</td>
                <td class="px-5 py-3.5">$29.00</td>
                <td class="px-5 py-3.5"><span class="px-2 py-0.5 rounded-full text-[10px] font-semibold bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">Paid</span></td>
                <td class="px-5 py-3.5 text-right"><button class="view-invoice-btn text-white/80 hover:text-white font-medium underline underline-offset-4 cursor-pointer bg-transparent border-none p-0" data-invoice="RNY-05212026-0077">View Invoice</button></td>
              </tr>
              <tr class="border-b border-white/5 hover:bg-white/5 transition-colors">
                <td class="px-5 py-3.5 font-mono text-white/90">RNY-04212026-0051</td>
                <td class="px-5 py-3.5">Apr 21, 2026</td>
                <td class="px-5 py-3.5">$29.00</td>
                <td class="px-5 py-3.5"><span class="px-2 py-0.5 rounded-full text-[10px] font-semibold bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">Paid</span></td>
                <td class="px-5 py-3.5 text-right"><button class="view-invoice-btn text-white/80 hover:text-white font-medium underline underline-offset-4 cursor-pointer bg-transparent border-none p-0" data-invoice="RNY-04212026-0051">View Invoice</button></td>
              </tr>
              <tr class="hover:bg-white/5 transition-colors">
                <td class="px-5 py-3.5 font-mono text-white/90">RNY-03212026-0024</td>
                <td class="px-5 py-3.5">Mar 21, 2026</td>
                <td class="px-5 py-3.5">$29.00</td>
                <td class="px-5 py-3.5"><span class="px-2 py-0.5 rounded-full text-[10px] font-semibold bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">Paid</span></td>
                <td class="px-5 py-3.5 text-right"><button class="view-invoice-btn text-white/80 hover:text-white font-medium underline underline-offset-4 cursor-pointer bg-transparent border-none p-0" data-invoice="RNY-03212026-0024">View Invoice</button></td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

    </div>
  </div>

  <!-- Printable Invoice Dialog Overlay -->
  <div id="invoice-modal-overlay" class="fixed inset-0 bg-black/70 backdrop-blur-sm z-[100] flex items-center justify-center p-6 hidden pointer-events-none opacity-0 transition-opacity duration-200">
    <div id="invoice-modal-content" class="bg-white rounded-[14px] w-full max-w-[620px] max-h-[90vh] overflow-y-auto shadow-2xl relative pointer-events-auto p-8 flex flex-col gap-6 text-[#262626] font-sans opacity-0 scale-[0.96] translate-y-4">
      
      <!-- Close Button -->
      <button id="close-invoice-modal-btn" class="absolute top-4 right-4 text-ash hover:text-ink cursor-pointer bg-transparent border-none p-1" aria-label="Close invoice">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg>
      </button>

      <!-- Invoice Artwork Header -->
      <div class="w-full h-32 rounded-lg bg-cover bg-center bg-no-repeat overflow-hidden grayscale contrast-[1.2] border border-[#ededed]" style="background-image: url('/Background.png');">
        <!-- Grayscale filtered overlay to simulate the black and white hands artwork look -->
        <div class="w-full h-full bg-black/10 flex items-center justify-center">
          <span class="text-white/25 text-[10px] font-bold tracking-widest uppercase">K O V I R A</span>
        </div>
      </div>

      <!-- Invoice Meta Row -->
      <div class="flex justify-between items-start">
        <div class="flex items-center gap-2">
          <!-- Kovira Logo Symbol -->
          <div class="w-8 h-8 rounded-full bg-black flex items-center justify-center text-white">
            <svg class="w-5.5 h-auto text-white" viewBox="0 0 44 45" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M22.2782 6.3584C23.3828 6.3584 24.2782 7.25383 24.2782 8.3584V15.4716C24.3202 15.4824 24.3621 15.4936 24.4038 15.5052L28.96 7.61365L30.3071 8.39141C31.2636 8.94371 31.5914 10.1669 31.0391 11.1235L27.4822 17.2841C27.5129 17.3142 27.5433 17.3446 27.5734 17.3752L35.4668 12.818L36.2446 14.1652C36.7969 15.1218 36.4691 16.3449 35.5125 16.8972L29.3536 20.4531C29.3654 20.4956 29.3768 20.5382 29.3878 20.5811H38.5V22.1366C38.5 23.2412 37.6046 24.1366 36.5 24.1366H29.3878C29.377 24.1787 29.3658 24.2207 29.3542 24.2625L37.2446 28.818L36.4668 30.1652C35.9145 31.1218 34.6913 31.4495 33.7347 30.8973L27.5748 27.3409C27.5446 27.3717 27.5141 27.4022 27.4833 27.4324L32.0401 35.325L30.6931 36.1028C29.7365 36.6551 28.5133 36.3273 27.961 35.3708L24.4052 29.212C24.363 29.2237 24.3207 29.235 24.2782 29.2459V38.3584H22.7227C21.6181 38.3584 20.7227 37.463 20.7227 36.3584V29.2458C20.6802 29.2349 20.6379 29.2235 20.5958 29.2119L16.0392 37.1042L14.692 36.3264C13.7354 35.7742 13.4077 34.551 13.96 33.5944L17.5178 27.432C17.4868 27.4016 17.456 27.3708 17.4256 27.3398L9.53168 31.8973L8.75387 30.55C8.2016 29.5934 8.52936 28.3703 9.48594 27.818L15.6469 24.261C15.6355 24.2197 15.6244 24.1782 15.6137 24.1366H6.5V22.5811C6.5 21.4765 7.39543 20.5811 8.5 20.5811H15.6137C15.6246 20.5388 15.6358 20.4966 15.6475 20.4546L7.75391 15.8972L8.53169 14.5501C9.08397 13.5935 10.3071 13.2657 11.2637 13.818L17.427 17.3763C17.4573 17.3455 17.4879 17.3148 17.5188 17.2845L12.9609 9.39008L14.3081 8.61231C15.2647 8.06002 16.4879 8.38777 17.0401 9.34436L20.5972 15.5053C20.6388 15.4938 20.6807 15.4826 20.7227 15.4718V6.3584H22.2782ZM25.647 24.0166L25.5129 24.2489C25.2237 24.7087 24.8322 25.0977 24.3703 25.3838L24.1802 25.4935C23.6947 25.7542 23.1416 25.9053 22.554 25.914H22.4475C20.5083 25.8855 18.9452 24.3047 18.9452 22.3588C18.9452 20.3951 20.537 18.8032 22.5008 18.8032C23.1125 18.8032 23.6882 18.9577 24.1909 19.2298L24.3599 19.3274C24.8366 19.6204 25.239 20.0227 25.532 20.4994L25.6299 20.669C25.8909 21.1513 26.0436 21.7007 26.0556 22.2847V22.4329C26.0439 23.0041 25.8975 23.5421 25.647 24.0166Z" fill="currentColor"/>
            </svg>
          </div>
          <span class="text-xs font-bold tracking-tight">Kovira</span>
        </div>
        <span class="text-[10px] font-semibold text-ash font-mono" id="invoice-modal-id">RNY-05212026-0077</span>
      </div>

      <!-- INVOICE Main Header -->
      <div>
        <h2 class="text-4xl font-extrabold tracking-[-0.04em] leading-none mb-1 text-black">INVOICE</h2>
      </div>

      <!-- Address / Meta Information -->
      <div class="grid grid-cols-3 gap-4 text-[10px] leading-relaxed text-ash border-b border-[#ededed] pb-5">
        <div>
          <span class="block text-[#a0a0a0] uppercase font-semibold text-[8px] mb-1">From</span>
          <strong class="text-ink font-semibold">Kovira Inc.</strong><br />
          billing@kovira.dev<br />
          548 Market St, San Francisco<br />
          California, US<br />
          +1 415 889 2201
        </div>
        <div>
          <span class="block text-[#a0a0a0] uppercase font-semibold text-[8px] mb-1">Bill To</span>
          <strong class="text-ink font-semibold" id="invoice-modal-bill-to">Kirian Dev</strong><br />
          kirian@kovira.dev<br />
          Av. de la Reforma 250<br />
          Ciudad de México, MX<br />
          VAT MX9920194812
        </div>
        <div class="text-right">
          <span class="block text-[#a0a0a0] uppercase font-semibold text-[8px] mb-1 text-right">Issued</span>
          <span class="text-ink font-semibold" id="invoice-modal-date">May 21, 2026</span>
          <span class="block text-[#a0a0a0] uppercase font-semibold text-[8px] mt-2 mb-1 text-right">Due</span>
          <span class="text-ink font-semibold">Immediate</span>
        </div>
      </div>

      <!-- Items Table -->
      <div class="w-full flex flex-col">
        <div class="grid grid-cols-[1fr_50px_80px_80px] border-b border-[#ededed] py-2 text-[9px] font-bold text-[#a0a0a0] uppercase">
          <div>Description</div>
          <div class="text-center">Qty</div>
          <div class="text-right">Price</div>
          <div class="text-right">Amount</div>
        </div>
        <div class="grid grid-cols-[1fr_50px_80px_80px] border-b border-[#ededed] py-3.5 text-xs text-ink font-medium">
          <div>Kovira SaaS platform — Pro Subscription Plan</div>
          <div class="text-center font-mono">1</div>
          <div class="text-right font-mono">$29.00</div>
          <div class="text-right font-mono">$29.00</div>
        </div>
      </div>

      <!-- Totals -->
      <div class="flex flex-col items-end gap-1.5 text-xs font-medium pr-1 mt-2 text-ink">
        <div class="flex justify-between w-[200px] border-b border-[#ededed]/60 pb-1">
          <span class="text-ash">Subtotal</span>
          <span class="font-mono">$29.00</span>
        </div>
        <div class="flex justify-between w-[200px] border-b border-[#ededed]/60 pb-1">
          <span class="text-ash">Tax (0%)</span>
          <span class="font-mono">$0.00</span>
        </div>
        <div class="flex justify-between w-[200px] font-bold text-black text-sm">
          <span>Total</span>
          <span class="font-mono">$29.00 USD</span>
        </div>
      </div>

      <!-- Payment details & Notes -->
      <div class="grid grid-cols-2 gap-4 text-[9px] leading-relaxed text-ash border-t border-[#ededed] pt-5 mt-2">
        <div>
          <span class="block text-[#a0a0a0] uppercase font-semibold text-[8px] mb-1">Payment Details</span>
          Payment Method: Credit Card<br />
          Card Vendor: <span id="invoice-modal-card-vendor">Visa Ending 4242</span><br />
          Payment Gateway: Stripe Secure
        </div>
        <div>
          <span class="block text-[#a0a0a0] uppercase font-semibold text-[8px] mb-1">Notes</span>
          Thank you for building with Kovira! Subscriptions renew automatically.
        </div>
      </div>

      <!-- Print Button -->
      <div class="w-full flex justify-end gap-2 mt-4">
        <button onclick="window.print()" class="bg-[#262626] text-white border border-[#262626] px-5 py-2.5 rounded-buttons text-xs font-semibold hover:bg-black transition-colors cursor-pointer">
          Print Invoice
        </button>
      </div>

    </div>
  </div>

  <!-- Interactive Update Payment Method Drawer Modal -->
  <div id="payment-modal-overlay" class="fixed inset-0 bg-black/70 backdrop-blur-sm z-[100] flex items-center justify-center p-6 hidden pointer-events-none opacity-0 transition-opacity duration-200">
    <div id="payment-modal-content" class="bg-white rounded-[14px] w-full max-w-[420px] shadow-2xl relative pointer-events-auto p-8 flex flex-col gap-5 text-[#262626] font-sans opacity-0 scale-[0.96] translate-y-4">
      
      <!-- Close Button -->
      <button id="close-payment-modal-btn" class="absolute top-4 right-4 text-ash hover:text-ink cursor-pointer bg-transparent border-none p-1" aria-label="Close form">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg>
      </button>

      <div>
        <h3 class="text-lg font-bold text-black tracking-tight mb-1">Update Payment Method</h3>
        <p class="text-xs text-ash leading-relaxed">Enter your billing information below to link a new card.</p>
      </div>

      <!-- Supported Cards Row -->
      <div class="flex items-center gap-2 border-b border-[#ededed] pb-3.5">
        <span class="text-[9px] font-bold text-[#a0a0a0] uppercase">We accept</span>
        <div class="flex gap-1.5 ml-auto">
          <!-- Visa logo icon -->
          <div id="logo-visa" class="w-7 h-5 rounded border border-[#ededed] bg-[#fbfbfb] flex items-center justify-center text-[8px] font-black text-blue-800 opacity-60">VISA</div>
          <!-- Mastercard logo icon -->
          <div id="logo-mastercard" class="w-7 h-5 rounded border border-[#ededed] bg-[#fbfbfb] flex items-center justify-center text-[8px] font-black text-orange-600 opacity-60">MC</div>
          <!-- Amex logo icon -->
          <div id="logo-amex" class="w-7 h-5 rounded border border-[#ededed] bg-[#fbfbfb] flex items-center justify-center text-[8px] font-black text-cyan-600 opacity-60">AMEX</div>
        </div>
      </div>

      <form id="payment-update-form" class="flex flex-col gap-4">
        <!-- Cardholder Name -->
        <div class="flex flex-col gap-1.5">
          <label class="text-[10px] font-bold text-ink uppercase tracking-wide">Cardholder Name</label>
          <input type="text" id="cardholder-name" required placeholder="Kirian Dev" class="w-full border border-[#ededed] rounded-buttons px-3 py-2 text-xs focus:outline-none focus:border-[#262626] placeholder-[#cbcbcb] text-[#262626] font-sans" />
        </div>

        <!-- Card Number -->
        <div class="flex flex-col gap-1.5 relative">
          <label class="text-[10px] font-bold text-ink uppercase tracking-wide">Card Number</label>
          <div class="relative">
            <input type="text" id="card-number" required maxlength="19" placeholder="4000 1234 5678 9010" class="w-full border border-[#ededed] rounded-buttons pl-3 pr-10 py-2 text-xs focus:outline-none focus:border-[#262626] placeholder-[#cbcbcb] text-[#262626] font-sans font-mono" />
            <!-- Floating brand indicator inside input -->
            <div class="absolute right-3 top-1/2 -translate-y-1/2 text-[8px] font-black text-ash uppercase font-mono" id="card-input-brand-indicator">CARD</div>
          </div>
        </div>

        <!-- Expiry & CVC Grid -->
        <div class="grid grid-cols-2 gap-3">
          <div class="flex flex-col gap-1.5">
            <label class="text-[10px] font-bold text-ink uppercase tracking-wide">Expiration</label>
            <input type="text" id="card-expiry" required maxlength="5" placeholder="MM/YY" class="w-full border border-[#ededed] rounded-buttons px-3 py-2 text-xs focus:outline-none focus:border-[#262626] placeholder-[#cbcbcb] text-[#262626] font-sans font-mono text-center" />
          </div>
          <div class="flex flex-col gap-1.5">
            <label class="text-[10px] font-bold text-ink uppercase tracking-wide">CVC</label>
            <input type="password" id="card-cvc" required maxlength="4" placeholder="•••" class="w-full border border-[#ededed] rounded-buttons px-3 py-2 text-xs focus:outline-none focus:border-[#262626] placeholder-[#cbcbcb] text-[#262626] font-sans font-mono text-center" />
          </div>
        </div>

        <!-- Actions -->
        <div class="flex items-center gap-3 mt-2 border-t border-[#ededed] pt-4">
          <button type="submit" id="save-card-btn" class="flex-1 bg-[#262626] text-white border border-[#262626] py-2.5 rounded-buttons text-xs font-semibold hover:bg-black transition-colors cursor-pointer flex justify-center items-center gap-2">
            <span>Update Card</span>
          </button>
          <button type="button" id="cancel-payment-modal-btn" class="bg-transparent text-ash border border-[#ededed] py-2.5 px-4 rounded-buttons text-xs font-medium hover:text-ink hover:border-ash transition-all cursor-pointer">
            Cancel
          </button>
        </div>
      </form>

    </div>
  </div>

  <!-- Minimalist Success Toast -->
  <div id="billing-success-toast" class="fixed bottom-6 right-6 bg-[#262626] text-white text-xs font-medium py-3 px-5 rounded-buttons shadow-xl z-[150] border border-white/10 flex items-center gap-2 transform translate-y-24 opacity-0 transition-all duration-300 pointer-events-none">
    <svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"></path></svg>
    <span id="toast-message-text">Payment details updated successfully!</span>
  </div>

  <script>
    import { animate, stagger } from 'motion';

    document.addEventListener('astro:page-load', () => {
      // Elements
      const openInvoiceBtns = document.querySelectorAll('.view-invoice-btn');
      const invoiceOverlay = document.getElementById('invoice-modal-overlay');
      const invoiceContent = document.getElementById('invoice-modal-content');
      const closeInvoiceBtn = document.getElementById('close-invoice-modal-btn');
      const invoiceModalId = document.getElementById('invoice-modal-id');
      const invoiceModalDate = document.getElementById('invoice-modal-date');
      const invoiceModalCardVendor = document.getElementById('invoice-modal-card-vendor');

      const openPaymentBtn = document.getElementById('open-payment-modal-btn');
      const paymentOverlay = document.getElementById('payment-modal-overlay');
      const paymentContent = document.getElementById('payment-modal-content');
      const closePaymentBtn = document.getElementById('close-payment-modal-btn');
      const cancelPaymentBtn = document.getElementById('cancel-payment-modal-btn');
      const paymentForm = document.getElementById('payment-update-form');

      // Card brand logos in update form
      const logoVisa = document.getElementById('logo-visa');
      const logoMaster = document.getElementById('logo-mastercard');
      const logoAmex = document.getElementById('logo-amex');
      const cardBrandIndicator = document.getElementById('card-input-brand-indicator');

      // Card input fields
      const inputCardNumber = document.getElementById('card-number') as HTMLInputElement;
      const inputCardExpiry = document.getElementById('card-expiry') as HTMLInputElement;
      const inputCardholder = document.getElementById('cardholder-name') as HTMLInputElement;

      // Active UI payment details display
      const activeCardBrandText = document.getElementById('active-card-brand-text');
      const activeCardName = document.getElementById('active-card-name');
      const activeCardExpiry = document.getElementById('active-card-expiry');

      // Toast elements
      const successToast = document.getElementById('billing-success-toast');
      const toastText = document.getElementById('toast-message-text');

      let currentCardNumber = '4242';
      let currentCardBrand = 'VISA';
      let currentExpiry = '12/28';

      // Animate helper to open modal
      const openModal = (overlay: HTMLElement, content: HTMLElement) => {
        overlay.classList.remove('hidden');
        overlay.classList.remove('pointer-events-none');
        overlay.classList.add('pointer-events-auto');

        // Smooth fade-in overlay & slide-up scale content
        animate(overlay, { opacity: [0, 1] }, { duration: 0.22 });
        animate(
          content,
          { opacity: [0, 1], scale: [0.96, 1], y: [16, 0] },
          { duration: 0.36, easing: [0.16, 1, 0.3, 1] }
        );
      };

      // Animate helper to close modal
      const closeModal = (overlay: HTMLElement, content: HTMLElement) => {
        overlay.classList.remove('pointer-events-auto');
        overlay.classList.add('pointer-events-none');

        animate(overlay, { opacity: 0 }, { duration: 0.2 });
        animate(
          content,
          { opacity: 0, scale: 0.96, y: 16 },
          { duration: 0.2, easing: [0.16, 1, 0.3, 1] }
        ).then(() => {
          overlay.classList.add('hidden');
        });
      };

      // Show toast helper
      const showToast = (message: string) => {
        if (!successToast || !toastText) return;
        toastText.textContent = message;
        
        successToast.classList.remove('opacity-0', 'translate-y-24', 'pointer-events-none');
        successToast.classList.add('opacity-100', 'translate-y-0', 'pointer-events-auto');
        
        setTimeout(() => {
          successToast.classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto');
          successToast.classList.add('opacity-0', 'translate-y-24', 'pointer-events-none');
        }, 3000);
      };

      // Invoice Modal Open
      openInvoiceBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const invoiceId = btn.getAttribute('data-invoice');
          if (invoiceModalId) invoiceModalId.textContent = invoiceId || '';
          
          let dateStr = 'May 21, 2026';
          if (invoiceId?.includes('0421')) dateStr = 'Apr 21, 2026';
          if (invoiceId?.includes('0321')) dateStr = 'Mar 21, 2026';
          if (invoiceModalDate) invoiceModalDate.textContent = dateStr;
          if (invoiceModalCardVendor) invoiceModalCardVendor.textContent = `${currentCardBrand.charAt(0) + currentCardBrand.slice(1).toLowerCase()} Ending ${currentCardNumber}`;

          if (invoiceOverlay && invoiceContent) {
            openModal(invoiceOverlay, invoiceContent);
          }
        });
      });

      if (closeInvoiceBtn && invoiceOverlay && invoiceContent) {
        closeInvoiceBtn.addEventListener('click', () => {
          closeModal(invoiceOverlay, invoiceContent);
        });
      }

      // Payment Modal Open
      if (openPaymentBtn && paymentOverlay && paymentContent) {
        openPaymentBtn.addEventListener('click', () => {
          openModal(paymentOverlay, paymentContent);
        });
      }

      const closePaymentModal = () => {
        if (paymentOverlay && paymentContent) {
          closeModal(paymentOverlay, paymentContent);
        }
      };

      if (closePaymentBtn) closePaymentBtn.addEventListener('click', closePaymentModal);
      if (cancelPaymentBtn) cancelPaymentBtn.addEventListener('click', closePaymentModal);

      // Card Number input validation & branding display
      if (inputCardNumber) {
        inputCardNumber.addEventListener('input', (e) => {
          let value = inputCardNumber.value.replace(/\s+/g, '').replace(/[^0-9]/gi, '');
          let formattedValue = '';
          
          // Formatter (groups of 4)
          for (let i = 0; i < value.length; i++) {
            if (i > 0 && i % 4 === 0) formattedValue += ' ';
            formattedValue += value[i];
          }
          inputCardNumber.value = formattedValue;

          // Brand detection
          let brand = 'CARD';
          logoVisa?.classList.add('opacity-60');
          logoMaster?.classList.add('opacity-60');
          logoAmex?.classList.add('opacity-60');

          if (value.startsWith('4')) {
            brand = 'VISA';
            logoVisa?.classList.remove('opacity-60');
          } else if (value.startsWith('5')) {
            brand = 'MASTERCARD';
            logoMaster?.classList.remove('opacity-60');
          } else if (value.startsWith('37') || value.startsWith('34')) {
            brand = 'AMEX';
            logoAmex?.classList.remove('opacity-60');
          }

          if (cardBrandIndicator) {
            cardBrandIndicator.textContent = brand;
          }
        });
      }

      // Expiry MM/YY formatting helper
      if (inputCardExpiry) {
        inputCardExpiry.addEventListener('input', (e) => {
          let value = inputCardExpiry.value.replace(/\D/g, '');
          if (value.length >= 2) {
            inputCardExpiry.value = value.slice(0, 2) + '/' + value.slice(2, 4);
          } else {
            inputCardExpiry.value = value;
          }
        });
      }

      // Handle card form submission
      if (paymentForm) {
        paymentForm.addEventListener('submit', (e) => {
          e.preventDefault();

          const saveBtn = document.getElementById('save-card-btn');
          const saveBtnSpan = saveBtn?.querySelector('span');

          // Visual loading state
          if (saveBtn && saveBtnSpan) {
            saveBtn.setAttribute('disabled', 'true');
            saveBtnSpan.textContent = 'Linking card...';
          }

          setTimeout(() => {
            // Retrieve card digits
            const digitsVal = inputCardNumber.value.replace(/\s+/g, '');
            const cardholderVal = inputCardholder.value || 'Cardholder';
            const brandText = cardBrandIndicator?.textContent || 'VISA';
            
            currentCardNumber = digitsVal.slice(-4) || '9999';
            currentCardBrand = brandText;
            currentExpiry = inputCardExpiry.value || '12/28';

            // Update main page details
            if (activeCardBrandText) activeCardBrandText.textContent = currentCardBrand;
            if (activeCardName) activeCardName.textContent = `${currentCardBrand.charAt(0) + currentCardBrand.slice(1).toLowerCase()} ending in ${currentCardNumber}`;
            if (activeCardExpiry) activeCardExpiry.textContent = `Expires ${currentExpiry}`;

            // Reset loading & close modal
            if (saveBtn && saveBtnSpan) {
              saveBtn.removeAttribute('disabled');
              saveBtnSpan.textContent = 'Update Card';
            }

            closePaymentModal();
            showToast('Billing credit card updated successfully!');

            // Clear inputs
            paymentForm.reset();
            if (cardBrandIndicator) cardBrandIndicator.textContent = 'CARD';
            logoVisa?.classList.add('opacity-60');
            logoMaster?.classList.add('opacity-60');
            logoAmex?.classList.add('opacity-60');

          }, 1200);
        });
      }

      // Global Escape key modal handler
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          if (invoiceOverlay && !invoiceOverlay.classList.contains('hidden')) {
            closeModal(invoiceOverlay, invoiceContent!);
          }
          if (paymentOverlay && !paymentOverlay.classList.contains('hidden')) {
            closeModal(paymentOverlay, paymentContent!);
          }
        }
      });

    });
  </script>
</Layout>
