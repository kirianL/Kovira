---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Billing & Subscription — Kovira" activeTab="billing">
  <div class="relative z-5 flex-1 flex flex-col items-center px-6 py-10 max-w-[900px] mx-auto w-full max-[768px]:px-5 max-[768px]:py-6 overflow-y-auto max-[768px]:justify-start">
    
    <!-- Title Section -->
    <div class="w-full text-left mb-8">
      <h1 class="text-[28px] font-extrabold leading-tight tracking-[-0.025em] text-white mb-2">
        <span class="reveal-wrapper">
          <span class="reveal-text delay-1">Billing & Subscription</span>
        </span>
      </h1>
      <p class="text-xs text-white/60 animate-fade-in delay-2">
        Manage your subscription plan, update payment methods, and view your billing history.
      </p>
    </div>

    <div class="w-full flex flex-col gap-6 text-left animate-fade-in delay-3">
      
      <!-- Top Grid: Subscription & Payment Details -->
      <div class="grid grid-cols-2 gap-4 max-[768px]:grid-cols-1">
        
        <!-- Current Plan Card -->
        <div class="p-5 rounded-cards border border-white/10 bg-[#0d0e1e] flex flex-col justify-between">
          <div>
            <div class="text-[10px] font-bold text-ash uppercase tracking-wider mb-2">Current Plan</div>
            <div class="flex items-baseline gap-2 mb-2">
              <span class="text-xl font-bold text-white">Pro Plan</span>
              <span class="text-xs text-white/60">$29.00 / month</span>
            </div>
            <p class="text-xs text-white/50 leading-relaxed mb-4">
              Your next billing date is July 20, 2026. You are currently utilizing 4 of 5 team members.
            </p>
          </div>
          <div class="flex items-center gap-3 mt-2">
            <button class="bg-[#262626] text-white border border-white/15 px-4 py-2 rounded-buttons text-xs font-semibold hover:bg-[#171717] transition-all cursor-pointer btn-primary-shadow">
              Change Plan
            </button>
            <button class="bg-transparent text-white/50 border border-white/10 px-4 py-2 rounded-buttons text-xs font-medium hover:text-white hover:border-white/20 transition-all cursor-pointer">
              Cancel
            </button>
          </div>
        </div>

        <!-- Payment Method Card -->
        <div class="p-5 rounded-cards border border-white/10 bg-[#0d0e1e] flex flex-col justify-between">
          <div>
            <div class="text-[10px] font-bold text-ash uppercase tracking-wider mb-2">Payment Details</div>
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-6 bg-white/5 rounded border border-white/10 flex items-center justify-center">
                <span class="text-[10px] font-extrabold text-white">VISA</span>
              </div>
              <div>
                <div class="text-xs font-semibold text-white">Visa ending in 4242</div>
                <div class="text-[10px] text-white/50">Expires 12/28</div>
              </div>
            </div>
            <p class="text-xs text-white/50 leading-relaxed mb-4">
              Charges appear as "KOVIRA* PLATFORM" on your statement.
            </p>
          </div>
          <div class="flex items-center gap-2 mt-2">
            <button class="bg-transparent text-white/80 border border-white/10 px-4 py-2 rounded-buttons text-xs font-medium hover:text-white hover:border-white/20 transition-all cursor-pointer">
              Update Payment Method
            </button>
          </div>
        </div>

      </div>

      <!-- Bottom: Invoice History Table -->
      <div class="mt-4">
        <h2 class="text-sm font-bold text-white uppercase tracking-wider mb-4">Billing History</h2>
        
        <div class="w-full overflow-x-auto border border-white/10 rounded-cards bg-[#0d0e1e]">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="border-b border-white/10 text-[10px] text-ash uppercase font-bold tracking-wider">
                <th class="px-5 py-3">Invoice Number</th>
                <th class="px-5 py-3">Billing Date</th>
                <th class="px-5 py-3">Amount</th>
                <th class="px-5 py-3">Status</th>
                <th class="px-5 py-3 text-right">Action</th>
              </tr>
            </thead>
            <tbody class="text-xs text-white/80">
              <tr class="border-b border-white/5 hover:bg-white/5 transition-colors">
                <td class="px-5 py-3.5 font-mono text-white/90">RNY-05212026-0077</td>
                <td class="px-5 py-3.5">May 21, 2026</td>
                <td class="px-5 py-3.5">$29.00</td>
                <td class="px-5 py-3.5"><span class="px-2 py-0.5 rounded-full text-[10px] font-semibold bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">Paid</span></td>
                <td class="px-5 py-3.5 text-right"><button class="view-invoice-btn text-white/80 hover:text-white font-medium underline underline-offset-4 cursor-pointer" data-invoice="RNY-05212026-0077">View Invoice</button></td>
              </tr>
              <tr class="border-b border-white/5 hover:bg-white/5 transition-colors">
                <td class="px-5 py-3.5 font-mono text-white/90">RNY-04212026-0051</td>
                <td class="px-5 py-3.5">Apr 21, 2026</td>
                <td class="px-5 py-3.5">$29.00</td>
                <td class="px-5 py-3.5"><span class="px-2 py-0.5 rounded-full text-[10px] font-semibold bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">Paid</span></td>
                <td class="px-5 py-3.5 text-right"><button class="view-invoice-btn text-white/80 hover:text-white font-medium underline underline-offset-4 cursor-pointer" data-invoice="RNY-04212026-0051">View Invoice</button></td>
              </tr>
              <tr class="hover:bg-white/5 transition-colors">
                <td class="px-5 py-3.5 font-mono text-white/90">RNY-03212026-0024</td>
                <td class="px-5 py-3.5">Mar 21, 2026</td>
                <td class="px-5 py-3.5">$29.00</td>
                <td class="px-5 py-3.5"><span class="px-2 py-0.5 rounded-full text-[10px] font-semibold bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">Paid</span></td>
                <td class="px-5 py-3.5 text-right"><button class="view-invoice-btn text-white/80 hover:text-white font-medium underline underline-offset-4 cursor-pointer" data-invoice="RNY-03212026-0024">View Invoice</button></td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

    </div>
  </div>

  <!-- Printable Invoice Dialog Overlay -->
  <div id="invoice-modal-overlay" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-[100] flex items-center justify-center p-6 hidden pointer-events-none opacity-0 transition-opacity duration-200">
    <div class="bg-white rounded-[14px] w-full max-w-[620px] max-h-[90vh] overflow-y-auto shadow-2xl relative pointer-events-auto p-8 flex flex-col gap-6 text-[#262626] font-sans">
      
      <!-- Close Button -->
      <button id="close-invoice-modal-btn" class="absolute top-4 right-4 text-ash hover:text-ink cursor-pointer bg-transparent border-none p-1" aria-label="Close invoice">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg>
      </button>

      <!-- Invoice Artwork Header -->
      <div class="w-full h-32 rounded-lg bg-cover bg-center bg-no-repeat overflow-hidden grayscale contrast-[1.2]" style="background-image: url('/Background.png');">
        <!-- Grayscale filtered overlay to simulate the black and white hands artwork look -->
        <div class="w-full h-full bg-black/10 flex items-center justify-center">
          <span class="text-white/25 text-[10px] font-bold tracking-widest uppercase">K O V I R A</span>
        </div>
      </div>

      <!-- Invoice Meta Row -->
      <div class="flex justify-between items-start">
        <div class="flex items-center gap-2">
          <!-- Kovira Logo Symbol -->
          <div class="w-8 h-8 rounded-full bg-black flex items-center justify-center text-white">
            <svg class="w-5.5 h-auto text-white" viewBox="0 0 44 45" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M22.2782 6.3584C23.3828 6.3584 24.2782 7.25383 24.2782 8.3584V15.4716C24.3202 15.4824 24.3621 15.4936 24.4038 15.5052L28.96 7.61365L30.3071 8.39141C31.2636 8.94371 31.5914 10.1669 31.0391 11.1235L27.4822 17.2841C27.5129 17.3142 27.5433 17.3446 27.5734 17.3752L35.4668 12.818L36.2446 14.1652C36.7969 15.1218 36.4691 16.3449 35.5125 16.8972L29.3536 20.4531C29.3654 20.4956 29.3768 20.5382 29.3878 20.5811H38.5V22.1366C38.5 23.2412 37.6046 24.1366 36.5 24.1366H29.3878C29.377 24.1787 29.3658 24.2207 29.3542 24.2625L37.2446 28.818L36.4668 30.1652C35.9145 31.1218 34.6913 31.4495 33.7347 30.8973L27.5748 27.3409C27.5446 27.3717 27.5141 27.4022 27.4833 27.4324L32.0401 35.325L30.6931 36.1028C29.7365 36.6551 28.5133 36.3273 27.961 35.3708L24.4052 29.212C24.363 29.2237 24.3207 29.235 24.2782 29.2459V38.3584H22.7227C21.6181 38.3584 20.7227 37.463 20.7227 36.3584V29.2458C20.6802 29.2349 20.6379 29.2235 20.5958 29.2119L16.0392 37.1042L14.692 36.3264C13.7354 35.7742 13.4077 34.551 13.96 33.5944L17.5178 27.432C17.4868 27.4016 17.456 27.3708 17.4256 27.3398L9.53168 31.8973L8.75387 30.55C8.2016 29.5934 8.52936 28.3703 9.48594 27.818L15.6469 24.261C15.6355 24.2197 15.6244 24.1782 15.6137 24.1366H6.5V22.5811C6.5 21.4765 7.39543 20.5811 8.5 20.5811H15.6137C15.6246 20.5388 15.6358 20.4966 15.6475 20.4546L7.75391 15.8972L8.53169 14.5501C9.08397 13.5935 10.3071 13.2657 11.2637 13.818L17.427 17.3763C17.4573 17.3455 17.4879 17.3148 17.5188 17.2845L12.9609 9.39008L14.3081 8.61231C15.2647 8.06002 16.4879 8.38777 17.0401 9.34436L20.5972 15.5053C20.6388 15.4938 20.6807 15.4826 20.7227 15.4718V6.3584H22.2782ZM25.647 24.0166L25.5129 24.2489C25.2237 24.7087 24.8322 25.0977 24.3703 25.3838L24.1802 25.4935C23.6947 25.7542 23.1416 25.9053 22.554 25.914H22.4475C20.5083 25.8855 18.9452 24.3047 18.9452 22.3588C18.9452 20.3951 20.537 18.8032 22.5008 18.8032C23.1125 18.8032 23.6882 18.9577 24.1909 19.2298L24.3599 19.3274C24.8366 19.6204 25.239 20.0227 25.532 20.4994L25.6299 20.669C25.8909 21.1513 26.0436 21.7007 26.0556 22.2847V22.4329C26.0439 23.0041 25.8975 23.5421 25.647 24.0166Z" fill="currentColor"/>
            </svg>
          </div>
          <span class="text-xs font-bold tracking-tight">Kovira</span>
        </div>
        <span class="text-[10px] font-semibold text-ash font-mono" id="invoice-modal-id">RNY-05212026-0077</span>
      </div>

      <!-- INVOICE Main Header -->
      <div>
        <h2 class="text-4xl font-extrabold tracking-[-0.04em] leading-none mb-1 text-black">INVOICE</h2>
      </div>

      <!-- Address / Meta Information -->
      <div class="grid grid-cols-3 gap-4 text-[10px] leading-relaxed text-ash border-b border-[#ededed] pb-5">
        <div>
          <span class="block text-[#a0a0a0] uppercase font-semibold text-[8px] mb-1">From</span>
          <strong class="text-ink">Kovira Inc.</strong><br />
          billing@kovira.dev<br />
          548 Market St, San Francisco<br />
          California, US<br />
          +1 415 889 2201
        </div>
        <div>
          <span class="block text-[#a0a0a0] uppercase font-semibold text-[8px] mb-1">Bill To</span>
          <strong class="text-ink" id="invoice-modal-bill-to">Kirian Dev</strong><br />
          kirian@kovira.dev<br />
          Av. de la Reforma 250<br />
          Ciudad de México, MX<br />
          VAT MX9920194812
        </div>
        <div class="text-right">
          <span class="block text-[#a0a0a0] uppercase font-semibold text-[8px] mb-1 text-right">Issued</span>
          <span class="text-ink font-semibold" id="invoice-modal-date">May 21, 2026</span>
          <span class="block text-[#a0a0a0] uppercase font-semibold text-[8px] mt-2 mb-1 text-right">Due</span>
          <span class="text-ink font-semibold">Immediate</span>
        </div>
      </div>

      <!-- Items Table -->
      <div class="w-full flex flex-col">
        <div class="grid grid-cols-[1fr_50px_80px_80px] border-b border-[#ededed] py-2 text-[9px] font-bold text-[#a0a0a0] uppercase">
          <div>Description</div>
          <div class="text-center">Qty</div>
          <div class="text-right">Price</div>
          <div class="text-right">Amount</div>
        </div>
        <div class="grid grid-cols-[1fr_50px_80px_80px] border-b border-[#ededed] py-3.5 text-xs text-ink font-medium">
          <div>Kovira SaaS platform — Pro Subscription Plan</div>
          <div class="text-center">1</div>
          <div class="text-right">$29.00</div>
          <div class="text-right">$29.00</div>
        </div>
      </div>

      <!-- Totals -->
      <div class="flex flex-col items-end gap-1.5 text-xs font-medium pr-1 mt-2 text-ink">
        <div class="flex justify-between w-[200px] border-b border-[#ededed]/60 pb-1">
          <span class="text-ash">Subtotal</span>
          <span>$29.00</span>
        </div>
        <div class="flex justify-between w-[200px] border-b border-[#ededed]/60 pb-1">
          <span class="text-ash">Tax (0%)</span>
          <span>$0.00</span>
        </div>
        <div class="flex justify-between w-[200px] font-bold text-black text-sm">
          <span>Total</span>
          <span>$29.00 USD</span>
        </div>
      </div>

      <!-- Payment details & Notes -->
      <div class="grid grid-cols-2 gap-4 text-[9px] leading-relaxed text-ash border-t border-[#ededed] pt-5 mt-2">
        <div>
          <span class="block text-[#a0a0a0] uppercase font-semibold text-[8px] mb-1">Payment Details</span>
          Payment Method: Credit Card<br />
          Card Vendor: Visa Ending 4242<br />
          Payment Gateway: Stripe Secure
        </div>
        <div>
          <span class="block text-[#a0a0a0] uppercase font-semibold text-[8px] mb-1">Notes</span>
          Thank you for building with Kovira! Subscriptions renew automatically.
        </div>
      </div>

      <!-- Print Button -->
      <div class="w-full flex justify-end gap-2 mt-4">
        <button onclick="window.print()" class="bg-[#262626] text-white border border-[#262626] px-4 py-2 rounded-buttons text-xs font-semibold hover:bg-black transition-colors cursor-pointer">
          Print Invoice
        </button>
      </div>

    </div>
  </div>

  <script>
    // Event listeners to handle modal open/close
    document.addEventListener('astro:page-load', () => {
      const openModalBtns = document.querySelectorAll('.view-invoice-btn');
      const modalOverlay = document.getElementById('invoice-modal-overlay');
      const closeModalBtn = document.getElementById('close-invoice-modal-btn');
      
      const invoiceModalId = document.getElementById('invoice-modal-id');
      const invoiceModalDate = document.getElementById('invoice-modal-date');

      openModalBtns.forEach(btn => {
        btn.addEventListener('click', (e) => {
          const invoiceId = btn.getAttribute('data-invoice');
          if (invoiceModalId) invoiceModalId.textContent = invoiceId || '';
          
          let dateStr = 'May 21, 2026';
          if (invoiceId?.includes('0421')) dateStr = 'Apr 21, 2026';
          if (invoiceId?.includes('0321')) dateStr = 'Mar 21, 2026';
          if (invoiceModalDate) invoiceModalDate.textContent = dateStr;

          if (modalOverlay) {
            modalOverlay.classList.remove('hidden');
            setTimeout(() => {
              modalOverlay.classList.remove('opacity-0', 'pointer-events-none');
              modalOverlay.classList.add('opacity-100', 'pointer-events-auto');
            }, 10);
          }
        });
      });

      if (closeModalBtn && modalOverlay) {
        closeModalBtn.addEventListener('click', () => {
          modalOverlay.classList.remove('opacity-100', 'pointer-events-auto');
          modalOverlay.classList.add('opacity-0', 'pointer-events-none');
          setTimeout(() => {
            modalOverlay.classList.add('hidden');
          }, 200);
        });
      }

      // Close modal on escape key
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && modalOverlay && !modalOverlay.classList.contains('hidden')) {
          modalOverlay.classList.remove('opacity-100', 'pointer-events-auto');
          modalOverlay.classList.add('opacity-0', 'pointer-events-none');
          setTimeout(() => {
            modalOverlay.classList.add('hidden');
          }, 200);
        }
      });
    });
  </script>
</Layout>
