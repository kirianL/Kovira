---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Submissions Manager — Kovira" activeTab="submissions">
    <div class="relative z-5 flex-1 flex flex-col items-center justify-center text-center px-6 py-8 max-w-[840px] mx-auto w-full max-[768px]:px-5 max-[768px]:py-6">
      
      <h1 class="text-[clamp(30px,_4.2vw,_48px)] font-extrabold leading-[1.12] tracking-[-0.025em] mb-3 max-[768px]:mb-1.5 flex flex-col items-center gap-0.5 max-[768px]:text-[clamp(22px,_7vw,_32px)] text-white">
        <span class="reveal-wrapper">
          <span class="reveal-text delay-1">Securely collect, search</span>
        </span>
        <span class="reveal-wrapper">
          <span class="reveal-text delay-2">and manage submission data.</span>
        </span>
      </h1>
      
      <p class="text-[clamp(13.5px,_1.5vw,_16px)] text-white/80 max-w-[540px] leading-relaxed mb-5 max-[768px]:text-[13px] max-[768px]:mb-2.5 max-[768px]:max-w-[95%] animate-fade-in delay-3">
        Review data records in real-time. Export schemas, filter through submissions, and trigger structured pipelines. Keep your customer information secure.
      </p>

      <div class="flex justify-center mb-8 max-[768px]:w-full max-[768px]:max-w-[280px] max-[768px]:mb-3 animate-fade-in delay-4">
        <button class="open-login-btn bg-ink text-white px-6 py-2.5 rounded-buttons text-sm font-medium tracking-[-0.025em] border border-white/15 btn-primary-shadow transition-all duration-200 hover:bg-charcoal hover:-translate-y-[1px] cursor-pointer max-[768px]:w-full max-[768px]:py-3">Manage Submissions</button>
      </div>

      <div class="flex items-center justify-center gap-1.5 p-1 bg-white/5 border border-white/10 backdrop-blur-md rounded-full mb-6 max-[768px]:mb-3 animate-fade-in delay-4">
        <span class="px-4 py-1.5 rounded-full text-xs font-semibold bg-white text-ink">Interactive Submissions Preview</span>
      </div>

      <div class="w-full max-w-[720px] h-[260px] border border-soft-mist rounded-[12px] bg-white mockup-shadow overflow-hidden flex text-left max-[768px]:h-[170px] animate-fade-in delay-4">
        
        <div class="w-36 bg-[#fcfcfc] border-r border-soft-mist p-3.5 flex flex-col gap-2 max-[768px]:w-10 max-[768px]:p-1.5">
          <div class="flex items-center gap-2 max-[768px]:justify-center">
            <div class="w-3.5 h-3.5 bg-ink/10 rounded-sm"></div>
            <div class="h-2 w-14 bg-ink/15 rounded-sm max-[768px]:hidden"></div>
          </div>
          <div class="w-full h-[1px] bg-soft-mist my-1"></div>
          <div class="flex flex-col gap-1.5">
            <div class="flex items-center gap-2 p-1 bg-[#ededed] rounded-[4px] max-[768px]:justify-center">
              <svg class="w-3.5 h-3.5 text-ink flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"></path></svg>
              <div class="h-1.5 w-16 bg-ink/20 rounded-sm max-[768px]:hidden"></div>
            </div>
          </div>
        </div>

        <div class="flex-1 p-5 overflow-hidden flex flex-col bg-white max-[768px]:p-3 text-ink">
          <div class="flex items-center justify-between border-b border-soft-mist pb-3 mb-3 max-[768px]:pb-2 max-[768px]:mb-2">
            <div class="flex flex-col gap-1">
              <div class="h-3 w-32 bg-ink/70 rounded-sm max-[768px]:w-20"></div>
              <div class="h-1.5 w-44 bg-ash/40 rounded-sm max-[768px]:hidden"></div>
            </div>
            <div class="h-5 w-12 bg-ink/10 rounded-full max-[768px]:h-4 max-[768px]:w-8"></div>
          </div>

          <div class="flex-1 relative w-full h-full text-[10px] overflow-hidden">
            <table class="w-full text-left border-collapse">
              <thead>
                <tr class="border-b border-soft-mist text-ash">
                  <th class="pb-1.5 font-semibold">User</th>
                  <th class="pb-1.5 font-semibold">Email</th>
                  <th class="pb-1.5 font-semibold max-[768px]:hidden">Status</th>
                  <th class="pb-1.5 font-semibold">Submitted</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-soft-mist">
                <tr>
                  <td class="py-2 font-medium">Kirian Dev</td>
                  <td class="py-2 text-ash">kirian@kovira.dev</td>
                  <td class="py-2 max-[768px]:hidden"><span class="bg-emerald-500/10 text-emerald-600 px-1.5 py-0.5 rounded text-[8px] font-bold">SUCCESS</span></td>
                  <td class="py-2 text-ash">2 mins ago</td>
                </tr>
                <tr>
                  <td class="py-2 font-medium">Alice Smith</td>
                  <td class="py-2 text-ash">alice@example.com</td>
                  <td class="py-2 max-[768px]:hidden"><span class="bg-emerald-500/10 text-emerald-600 px-1.5 py-0.5 rounded text-[8px] font-bold">SUCCESS</span></td>
                  <td class="py-2 text-ash">10 mins ago</td>
                </tr>
                <tr>
                  <td class="py-2 font-medium">Bob Jones</td>
                  <td class="py-2 text-ash">bob@jones.com</td>
                  <td class="py-2 max-[768px]:hidden"><span class="bg-amber-500/10 text-amber-600 px-1.5 py-0.5 rounded text-[8px] font-bold">PENDING</span></td>
                  <td class="py-2 text-ash">1 hr ago</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
</Layout>
