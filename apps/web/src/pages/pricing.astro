---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Pricing — Kovira" activeTab="pricing">
    <div class="relative z-5 flex-1 flex flex-col items-center justify-center text-center px-6 py-8 max-w-[860px] mx-auto w-full max-[768px]:px-5 max-[768px]:py-6 max-[768px]:justify-start max-[768px]:overflow-y-auto">
      
      <h1 class="text-[clamp(30px,_4.2vw,_48px)] font-extrabold leading-[1.12] tracking-[-0.025em] mb-3 max-[768px]:mb-1.5 flex flex-col items-center gap-0.5 max-[768px]:text-[clamp(22px,_7vw,_32px)] text-white">
        <span class="reveal-wrapper">
          <span class="reveal-text delay-1">Simple, transparent</span>
        </span>
        <span class="reveal-wrapper">
          <span class="reveal-text delay-2">pricing for every team.</span>
        </span>
      </h1>
      
      <p class="text-[clamp(13.5px,_1.5vw,_16px)] text-white/80 max-w-[540px] leading-relaxed mb-5 max-[768px]:text-[13px] max-[768px]:mb-2.5 max-[768px]:max-w-[95%] animate-fade-in delay-3">
        Start free, scale as you grow. No hidden fees. Cancel anytime.
      </p>

      <!-- Pricing Cards -->
      <div class="grid grid-cols-3 gap-3.5 w-full max-w-[780px] text-left animate-fade-in delay-4 max-[768px]:grid-cols-1 max-[768px]:gap-3 max-[768px]:max-w-[340px]">
        
        <!-- Free -->
        <div class="pricing-card flex flex-col p-4 rounded-[14px] border border-soft-mist bg-white">
          <div class="text-[18px] font-semibold text-ink tracking-[-0.025em] mb-1.5">Free</div>
          <div class="flex items-baseline gap-1">
            <span class="text-[28px] font-semibold text-ink leading-none tracking-[-0.025em]">$0</span>
            <span class="text-[12px] text-ash font-medium tracking-[-0.025em]">/ month</span>
          </div>
          <p class="text-[12px] text-ash leading-snug tracking-[-0.025em] mt-1 mb-3.5">For individuals and small projects.</p>
          
          <ul class="flex flex-col gap-1 mb-4 flex-1">
            <li class="flex items-center gap-2 text-[12px] text-ink tracking-[-0.025em]">
              <svg class="w-3 h-3 text-ink flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"></path></svg>
              Up to 3 forms
            </li>
            <li class="flex items-center gap-2 text-[12px] text-ink tracking-[-0.025em]">
              <svg class="w-3 h-3 text-ink flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"></path></svg>
              100 submissions / mo
            </li>
            <li class="flex items-center gap-2 text-[12px] text-ink tracking-[-0.025em]">
              <svg class="w-3 h-3 text-ink flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"></path></svg>
              Basic analytics
            </li>
            <li class="flex items-center gap-2 text-[12px] text-ink tracking-[-0.025em]">
              <svg class="w-3 h-3 text-ink flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"></path></svg>
              1 team member
            </li>
          </ul>

          <button class="open-login-btn w-full py-2 px-4 rounded-buttons text-[12px] font-medium tracking-[-0.025em] border border-soft-mist text-ink bg-transparent transition-colors duration-200 hover:bg-[#fbfbfb] cursor-pointer">Get Started</button>
        </div>

        <!-- Pro (Featured) -->
        <div class="pricing-card pricing-card-featured relative flex flex-col p-4 rounded-[14px] border border-charcoal bg-charcoal">
          <div class="absolute -top-2.5 left-1/2 -translate-x-1/2 px-2.5 py-0.5 rounded-[9999px] text-[10px] font-medium tracking-[-0.025em] bg-mint-whisper text-emerald-700 leading-snug whitespace-nowrap">Popular Option</div>
          
          <div class="text-[18px] font-semibold text-white tracking-[-0.025em] mb-1.5">Pro</div>
          <div class="flex items-baseline gap-1">
            <span class="text-[28px] font-semibold text-white leading-none tracking-[-0.025em]">$29</span>
            <span class="text-[12px] text-chalk font-medium tracking-[-0.025em]">/ month</span>
          </div>
          <p class="text-[12px] text-chalk leading-snug tracking-[-0.025em] mt-1 mb-3.5">For growing teams that need more power.</p>
          
          <ul class="flex flex-col gap-1 mb-4 flex-1">
            <li class="flex items-center gap-2 text-[12px] text-white tracking-[-0.025em]">
              <svg class="w-3 h-3 text-white flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"></path></svg>
              Unlimited forms
            </li>
            <li class="flex items-center gap-2 text-[12px] text-white tracking-[-0.025em]">
              <svg class="w-3 h-3 text-white flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"></path></svg>
              10,000 submissions / mo
            </li>
            <li class="flex items-center gap-2 text-[12px] text-white tracking-[-0.025em]">
              <svg class="w-3 h-3 text-white flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"></path></svg>
              Advanced analytics
            </li>
            <li class="flex items-center gap-2 text-[12px] text-white tracking-[-0.025em]">
              <svg class="w-3 h-3 text-white flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"></path></svg>
              5 team members
            </li>
            <li class="flex items-center gap-2 text-[12px] text-white tracking-[-0.025em]">
              <svg class="w-3 h-3 text-white flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"></path></svg>
              API & webhooks
            </li>
            <li class="flex items-center gap-2 text-[12px] text-white tracking-[-0.025em]">
              <svg class="w-3 h-3 text-white flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"></path></svg>
              Custom branding
            </li>
          </ul>

          <button class="open-login-btn w-full py-2 px-4 rounded-buttons text-[12px] font-medium tracking-[-0.025em] border border-transparent bg-white text-ink transition-colors duration-200 hover:bg-soft-mist cursor-pointer">Start Free Trial</button>
        </div>

        <!-- Enterprise -->
        <div class="pricing-card flex flex-col p-4 rounded-[14px] border border-soft-mist bg-white">
          <div class="text-[18px] font-semibold text-ink tracking-[-0.025em] mb-1.5">Enterprise</div>
          <div class="flex items-baseline gap-1">
            <span class="text-[28px] font-semibold text-ink leading-none tracking-[-0.025em]">Custom</span>
          </div>
          <p class="text-[12px] text-ash leading-snug tracking-[-0.025em] mt-1 mb-3.5">Tailored for large organizations.</p>
          
          <ul class="flex flex-col gap-1 mb-4 flex-1">
            <li class="flex items-center gap-2 text-[12px] text-ink tracking-[-0.025em]">
              <svg class="w-3 h-3 text-ink flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"></path></svg>
              Everything in Pro
            </li>
            <li class="flex items-center gap-2 text-[12px] text-ink tracking-[-0.025em]">
              <svg class="w-3 h-3 text-ink flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"></path></svg>
              Unlimited submissions
            </li>
            <li class="flex items-center gap-2 text-[12px] text-ink tracking-[-0.025em]">
              <svg class="w-3 h-3 text-ink flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"></path></svg>
              Unlimited team members
            </li>
            <li class="flex items-center gap-2 text-[12px] text-ink tracking-[-0.025em]">
              <svg class="w-3 h-3 text-ink flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"></path></svg>
              SSO & audit logs
            </li>
            <li class="flex items-center gap-2 text-[12px] text-ink tracking-[-0.025em]">
              <svg class="w-3 h-3 text-ink flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"></path></svg>
              Dedicated support & SLA
            </li>
          </ul>

          <button class="open-login-btn w-full py-2 px-4 rounded-buttons text-[12px] font-medium tracking-[-0.025em] border border-soft-mist text-ink bg-transparent transition-colors duration-200 hover:bg-[#fbfbfb] cursor-pointer">Contact Sales</button>
        </div>

      </div>
    </div>
</Layout>
