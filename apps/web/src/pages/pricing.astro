---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Pricing — Kovira" activeTab="pricing">
    <div class="relative z-5 flex-1 flex flex-col items-center justify-center text-center px-6 py-4 max-w-[920px] mx-auto w-full max-[768px]:px-5 max-[768px]:py-2 overflow-hidden">
      
      <h1 class="text-[clamp(32px,_4.5vw,_52px)] font-extrabold leading-[1.12] tracking-[-0.025em] mb-3 max-[768px]:mb-2 flex flex-col items-center gap-1 max-[768px]:text-[clamp(24px,_8vw,_34px)] text-white">
        <span class="reveal-wrapper">
          <span class="reveal-text delay-1">Simple, transparent</span>
        </span>
        <span class="reveal-wrapper">
          <span class="reveal-text delay-2">pricing for every team.</span>
        </span>
      </h1>
      
      <p class="text-[clamp(14px,_1.6vw,_17px)] text-white/80 max-w-[520px] leading-relaxed mb-7 max-[768px]:text-[13.5px] max-[768px]:mb-4 max-[768px]:max-w-[95%] animate-fade-in delay-3">
        Start free, scale as you grow. No hidden fees. Cancel anytime.
      </p>

      <!-- Pricing Cards -->
      <div class="grid grid-cols-3 gap-4 w-full max-w-[820px] text-left animate-fade-in delay-4 max-[768px]:grid-cols-1 max-[768px]:gap-3 max-[768px]:max-w-[360px]">
        
        <!-- Free -->
        <div class="pricing-card flex flex-col p-5 rounded-[14px] border border-soft-mist bg-white max-[768px]:p-4">
          <div class="text-[20px] font-semibold text-ink tracking-[-0.025em] mb-2">Free</div>
          <div class="flex items-baseline gap-1 mb-0.5">
            <span class="text-[30px] font-semibold text-ink leading-none tracking-[-0.025em]">$0</span>
            <span class="text-[13px] text-ash font-medium tracking-[-0.025em]">/ month</span>
          </div>
          <p class="text-[13px] text-ash leading-snug tracking-[-0.025em] mt-1 mb-5">For individuals and small projects.</p>
          
          <ul class="flex flex-col gap-1.5 mb-5 flex-1">
            <li class="flex items-center gap-2 text-[13px] text-ink tracking-[-0.025em]">
              <svg class="w-3.5 h-3.5 text-ink flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"></path></svg>
              Up to 3 forms
            </li>
            <li class="flex items-center gap-2 text-[13px] text-ink tracking-[-0.025em]">
              <svg class="w-3.5 h-3.5 text-ink flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"></path></svg>
              100 submissions / mo
            </li>
            <li class="flex items-center gap-2 text-[13px] text-ink tracking-[-0.025em]">
              <svg class="w-3.5 h-3.5 text-ink flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"></path></svg>
              Basic analytics
            </li>
            <li class="flex items-center gap-2 text-[13px] text-ink tracking-[-0.025em]">
              <svg class="w-3.5 h-3.5 text-ink flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"></path></svg>
              1 team member
            </li>
          </ul>

          <button class="open-login-btn w-full py-2 px-5 rounded-buttons text-[13px] font-medium tracking-[-0.025em] border border-soft-mist text-ink bg-transparent transition-colors duration-200 hover:bg-[#fbfbfb] cursor-pointer">Get Started</button>
        </div>

        <!-- Pro (Featured) -->
        <div class="pricing-card pricing-card-featured relative flex flex-col p-5 rounded-[14px] border border-charcoal bg-charcoal max-[768px]:p-4">
          <!-- Popular pill -->
          <div class="absolute -top-2.5 left-1/2 -translate-x-1/2 px-3 py-0.5 rounded-[9999px] text-[11px] font-medium tracking-[-0.025em] bg-mint-whisper text-emerald-700 leading-snug">Popular Option</div>
          
          <div class="text-[20px] font-semibold text-white tracking-[-0.025em] mb-2">Pro</div>
          <div class="flex items-baseline gap-1 mb-0.5">
            <span class="text-[30px] font-semibold text-white leading-none tracking-[-0.025em]">$29</span>
            <span class="text-[13px] text-chalk font-medium tracking-[-0.025em]">/ month</span>
          </div>
          <p class="text-[13px] text-chalk leading-snug tracking-[-0.025em] mt-1 mb-5">For growing teams that need more power.</p>
          
          <ul class="flex flex-col gap-1.5 mb-5 flex-1">
            <li class="flex items-center gap-2 text-[13px] text-white tracking-[-0.025em]">
              <svg class="w-3.5 h-3.5 text-white flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"></path></svg>
              Unlimited forms
            </li>
            <li class="flex items-center gap-2 text-[13px] text-white tracking-[-0.025em]">
              <svg class="w-3.5 h-3.5 text-white flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"></path></svg>
              10,000 submissions / mo
            </li>
            <li class="flex items-center gap-2 text-[13px] text-white tracking-[-0.025em]">
              <svg class="w-3.5 h-3.5 text-white flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"></path></svg>
              Advanced analytics
            </li>
            <li class="flex items-center gap-2 text-[13px] text-white tracking-[-0.025em]">
              <svg class="w-3.5 h-3.5 text-white flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"></path></svg>
              5 team members
            </li>
            <li class="flex items-center gap-2 text-[13px] text-white tracking-[-0.025em]">
              <svg class="w-3.5 h-3.5 text-white flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"></path></svg>
              API access & webhooks
            </li>
            <li class="flex items-center gap-2 text-[13px] text-white tracking-[-0.025em]">
              <svg class="w-3.5 h-3.5 text-white flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"></path></svg>
              Custom branding
            </li>
          </ul>

          <button class="open-login-btn w-full py-2 px-5 rounded-buttons text-[13px] font-medium tracking-[-0.025em] border border-transparent bg-white text-ink transition-colors duration-200 hover:bg-soft-mist cursor-pointer">Start Free Trial</button>
        </div>

        <!-- Enterprise -->
        <div class="pricing-card flex flex-col p-5 rounded-[14px] border border-soft-mist bg-white max-[768px]:p-4">
          <div class="text-[20px] font-semibold text-ink tracking-[-0.025em] mb-2">Enterprise</div>
          <div class="flex items-baseline gap-1 mb-0.5">
            <span class="text-[30px] font-semibold text-ink leading-none tracking-[-0.025em]">Custom</span>
          </div>
          <p class="text-[13px] text-ash leading-snug tracking-[-0.025em] mt-1 mb-5">Tailored for large organizations.</p>
          
          <ul class="flex flex-col gap-1.5 mb-5 flex-1">
            <li class="flex items-center gap-2 text-[13px] text-ink tracking-[-0.025em]">
              <svg class="w-3.5 h-3.5 text-ink flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"></path></svg>
              Everything in Pro
            </li>
            <li class="flex items-center gap-2 text-[13px] text-ink tracking-[-0.025em]">
              <svg class="w-3.5 h-3.5 text-ink flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"></path></svg>
              Unlimited submissions
            </li>
            <li class="flex items-center gap-2 text-[13px] text-ink tracking-[-0.025em]">
              <svg class="w-3.5 h-3.5 text-ink flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"></path></svg>
              Unlimited team members
            </li>
            <li class="flex items-center gap-2 text-[13px] text-ink tracking-[-0.025em]">
              <svg class="w-3.5 h-3.5 text-ink flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"></path></svg>
              SSO & audit logs
            </li>
            <li class="flex items-center gap-2 text-[13px] text-ink tracking-[-0.025em]">
              <svg class="w-3.5 h-3.5 text-ink flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"></path></svg>
              Dedicated support & SLA
            </li>
          </ul>

          <button class="open-login-btn w-full py-2 px-5 rounded-buttons text-[13px] font-medium tracking-[-0.025em] border border-soft-mist text-ink bg-transparent transition-colors duration-200 hover:bg-[#fbfbfb] cursor-pointer">Contact Sales</button>
        </div>

      </div>
    </div>
</Layout>
