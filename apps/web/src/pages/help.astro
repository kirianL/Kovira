---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Help & Support — Kovira">
  <div class="relative z-5 flex-1 flex flex-col items-center px-6 py-12 max-w-[680px] mx-auto w-full max-[768px]:px-5 max-[768px]:py-8 overflow-y-auto max-[768px]:overflow-visible">
    
    <div class="w-full mb-6 flex justify-start">
      <button onclick="history.back()" class="flex items-center gap-1.5 text-xs text-white/50 hover:text-white transition-colors cursor-pointer bg-transparent border-none p-0">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"></path></svg>
        <span>Back</span>
      </button>
    </div>

    <h1 class="text-[clamp(24px,_3vw,_36px)] font-extrabold leading-[1.2] tracking-[-0.025em] mb-3 text-center text-white">
      <span class="reveal-wrapper">
        <span class="reveal-text delay-1">Help & Documentation</span>
      </span>
    </h1>
    
    <p class="text-xs text-white/60 max-w-[460px] leading-relaxed text-center mb-10 animate-fade-in delay-2">
      Find answers, read guides, and learn how to get the most out of Kovira's form builder.
    </p>

    <div class="w-full flex flex-col gap-8 text-left animate-fade-in delay-3">
      
      <!-- Minimalist Search Input -->
      <div class="w-full pb-4 border-b border-white/10">
        <input type="text" placeholder="Search documentation..." class="w-full bg-[#0d0e1e] border border-white/10 rounded-sm px-4 py-2.5 text-xs focus:outline-none focus:border-white/20 placeholder-white/30 text-white font-sans transition-colors duration-200" readonly />
      </div>

      <!-- Help Topics -->
      <div class="flex flex-col gap-6">
        <div class="pb-6 border-b border-white/10">
          <h3 class="text-xs font-bold text-white uppercase tracking-wider mb-2">Getting Started</h3>
          <p class="text-xs text-white/60 leading-relaxed mb-3">Learn the basics of creating forms, sharing links, and tracking responses.</p>
          <a href="#" class="text-xs font-medium text-white hover:text-white/80 transition-colors">Read Guide →</a>
        </div>

        <div class="pb-6 border-b border-white/10">
          <h3 class="text-xs font-bold text-white uppercase tracking-wider mb-2">Form Builder</h3>
          <p class="text-xs text-white/60 leading-relaxed mb-3">Understand form fields, conditional logic, file uploads, and customization.</p>
          <a href="#" class="text-xs font-medium text-white hover:text-white/80 transition-colors">Read Guide →</a>
        </div>

        <div class="pb-6 border-b border-white/10">
          <h3 class="text-xs font-bold text-white uppercase tracking-wider mb-2">Submissions</h3>
          <p class="text-xs text-white/60 leading-relaxed mb-3">Manage, filter, and export your responses to CSV or connect them to APIs.</p>
          <a href="#" class="text-xs font-medium text-white hover:text-white/80 transition-colors">Read Guide →</a>
        </div>

        <div class="pb-6 border-b border-white/10">
          <h3 class="text-xs font-bold text-white uppercase tracking-wider mb-2">Integrations</h3>
          <p class="text-xs text-white/60 leading-relaxed mb-3">Connect forms to webhooks, Slack, Discord, Google Sheets, or Zapier.</p>
          <a href="#" class="text-xs font-medium text-white hover:text-white/80 transition-colors">Read Guide →</a>
        </div>
      </div>

      <!-- FAQ Section -->
      <div class="mt-4 flex flex-col gap-6">
        <h2 class="text-sm font-bold text-white uppercase tracking-wider">Frequently Asked Questions</h2>
        
        <div class="flex flex-col gap-5">
          <div>
            <h4 class="text-xs font-semibold text-white mb-1.5">How many submissions can I receive on the free plan?</h4>
            <p class="text-[11px] text-white/60 leading-relaxed">The Free plan includes up to 100 submissions per month. If you exceed this limit, we'll notify you to upgrade, but we won't automatically block responses.</p>
          </div>
          
          <div>
            <h4 class="text-xs font-semibold text-white mb-1.5">Can I use my own custom domain?</h4>
            <p class="text-[11px] text-white/60 leading-relaxed">Yes! Custom domains are supported on the Pro and Enterprise plans. You can map any subdomain or root domain to your form links.</p>
          </div>
          
          <div class="pt-4 border-t border-white/10">
            <h4 class="text-xs font-semibold text-white mb-1.5">Need custom support?</h4>
            <p class="text-[11px] text-white/60 leading-relaxed">Can't find what you need? Reach out directly to our support team at <a href="mailto:support@kovira.dev" class="text-white hover:underline">support@kovira.dev</a> and we will assist you within 24 hours.</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</Layout>
