---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Help & Support — Kovira">
  <div class="relative z-5 flex-1 flex flex-col items-center px-6 py-10 max-w-[800px] mx-auto w-full max-[768px]:px-5 max-[768px]:py-6 overflow-y-auto">
    
    <h1 class="text-[clamp(28px,_3.5vw,_42px)] font-extrabold leading-[1.15] tracking-[-0.025em] mb-3 text-center text-white">
      <span class="reveal-wrapper">
        <span class="reveal-text delay-1">Help & Documentation</span>
      </span>
    </h1>
    
    <p class="text-[clamp(13px,_1.4vw,_15px)] text-white/80 max-w-[500px] leading-relaxed text-center mb-8 animate-fade-in delay-2">
      Find answers, read guides, and learn how to get the most out of Kovira's form builder.
    </p>

    <div class="w-full flex flex-col gap-6 text-left animate-fade-in delay-3">
      
      <!-- Search Mockup -->
      <div class="w-full relative">
        <input type="text" placeholder="Search documentation..." class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-white/30 placeholder-white/40 text-white font-sans transition-colors duration-200" readonly />
        <div class="absolute right-4 top-1/2 -translate-y-1/2 text-xs text-white/40 font-mono">⌘K</div>
      </div>

      <!-- Help Categories -->
      <div class="grid grid-cols-2 gap-4 max-[768px]:grid-cols-1">
        <div class="p-5 rounded-2xl border border-white/10 bg-white/5 backdrop-blur-md hover:border-white/20 transition-all duration-200">
          <h3 class="text-sm font-semibold text-white mb-2">Getting Started</h3>
          <p class="text-xs text-white/60 leading-relaxed mb-4">Learn the basics of creating forms, sharing links, and tracking responses.</p>
          <a href="#" class="text-xs font-medium text-white/80 hover:text-white underline underline-offset-4">Read Guide →</a>
        </div>
        <div class="p-5 rounded-2xl border border-white/10 bg-white/5 backdrop-blur-md hover:border-white/20 transition-all duration-200">
          <h3 class="text-sm font-semibold text-white mb-2">Form Builder</h3>
          <p class="text-xs text-white/60 leading-relaxed mb-4">Understand form fields, conditional logic, file uploads, and customization.</p>
          <a href="#" class="text-xs font-medium text-white/80 hover:text-white underline underline-offset-4">Read Guide →</a>
        </div>
        <div class="p-5 rounded-2xl border border-white/10 bg-white/5 backdrop-blur-md hover:border-white/20 transition-all duration-200">
          <h3 class="text-sm font-semibold text-white mb-2">Submissions</h3>
          <p class="text-xs text-white/60 leading-relaxed mb-4">Manage, filter, and export your responses to CSV or connect them to APIs.</p>
          <a href="#" class="text-xs font-medium text-white/80 hover:text-white underline underline-offset-4">Read Guide →</a>
        </div>
        <div class="p-5 rounded-2xl border border-white/10 bg-white/5 backdrop-blur-md hover:border-white/20 transition-all duration-200">
          <h3 class="text-sm font-semibold text-white mb-2">Integrations</h3>
          <p class="text-xs text-white/60 leading-relaxed mb-4">Connect forms to webhooks, Slack, Discord, Google Sheets, or Zapier.</p>
          <a href="#" class="text-xs font-medium text-white/80 hover:text-white underline underline-offset-4">Read Guide →</a>
        </div>
      </div>

      <!-- FAQ Section -->
      <div class="mt-4">
        <h2 class="text-lg font-bold text-white mb-4">Frequently Asked Questions</h2>
        <div class="flex flex-col gap-3.5">
          <div class="border-b border-white/10 pb-3">
            <h4 class="text-xs font-semibold text-white mb-1.5">How many submissions can I receive on the free plan?</h4>
            <p class="text-[11px] text-white/60 leading-relaxed">The Free plan includes up to 100 submissions per month. If you exceed this limit, we'll notify you to upgrade, but we won't automatically block responses.</p>
          </div>
          <div class="border-b border-white/10 pb-3">
            <h4 class="text-xs font-semibold text-white mb-1.5">Can I use my own custom domain?</h4>
            <p class="text-[11px] text-white/60 leading-relaxed">Yes! Custom domains are supported on the Pro and Enterprise plans. You can map any subdomain or root domain to your form links.</p>
          </div>
          <div class="pb-2">
            <h4 class="text-xs font-semibold text-white mb-1.5">Need custom support?</h4>
            <p class="text-[11px] text-white/60 leading-relaxed">Can't find what you need? Reach out directly to our support team at <a href="mailto:support@kovira.dev" class="text-white hover:underline">support@kovira.dev</a> and we will assist you within 24 hours.</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</Layout>
