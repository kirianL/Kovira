---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title: string;
  activeTab?: string;
}

const { title, activeTab } = Astro.props;
---
<html lang="en" class="overflow-hidden h-dvh w-full bg-[#090a16]">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>{title}</title>
  <meta name="description" content="Kovira is a multi-tenant SaaS platform for building forms, data collection systems and automations." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <ClientRouter />
</head>
<body class="overflow-hidden h-dvh w-full text-white antialiased tracking-[-0.025em] flex flex-col">

  <div id="landing-view" transition:name="landing-view" transition:animate="none" class="relative w-full h-dvh overflow-hidden flex flex-col justify-between bg-hero-pattern bg-cover bg-center bg-no-repeat hero-dot-matrix">
    
    <nav transition:name="navbar" transition:animate="none" class="relative z-10 grid grid-cols-[1fr_auto_1fr] items-center px-12 h-16 max-[768px]:px-6 max-[768px]:grid-cols-[1fr_auto]">
      <a href="/" class="flex items-center gap-2.5 justify-self-start text-white hover:opacity-90 transition-opacity cursor-pointer">
        <svg class="h-6 w-auto flex-shrink-0" viewBox="0 0 44 45" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path fill-rule="evenodd" clip-rule="evenodd" d="M22.2782 6.3584C23.3828 6.3584 24.2782 7.25383 24.2782 8.3584V15.4716C24.3202 15.4824 24.3621 15.4936 24.4038 15.5052L28.96 7.61365L30.3071 8.39141C31.2636 8.94371 31.5914 10.1669 31.0391 11.1235L27.4822 17.2841C27.5129 17.3142 27.5433 17.3446 27.5734 17.3752L35.4668 12.818L36.2446 14.1652C36.7969 15.1218 36.4691 16.3449 35.5125 16.8972L29.3536 20.4531C29.3654 20.4956 29.3768 20.5382 29.3878 20.5811H38.5V22.1366C38.5 23.2412 37.6046 24.1366 36.5 24.1366H29.3878C29.377 24.1787 29.3658 24.2207 29.3542 24.2625L37.2446 28.818L36.4668 30.1652C35.9145 31.1218 34.6913 31.4495 33.7347 30.8973L27.5748 27.3409C27.5446 27.3717 27.5141 27.4022 27.4833 27.4324L32.0401 35.325L30.6931 36.1028C29.7365 36.6551 28.5133 36.3273 27.961 35.3708L24.4052 29.212C24.363 29.2237 24.3207 29.235 24.2782 29.2459V38.3584H22.7227C21.6181 38.3584 20.7227 37.463 20.7227 36.3584V29.2458C20.6802 29.2349 20.6379 29.2235 20.5958 29.2119L16.0392 37.1042L14.692 36.3264C13.7354 35.7742 13.4077 34.551 13.96 33.5944L17.5178 27.432C17.4868 27.4016 17.456 27.3708 17.4256 27.3398L9.53168 31.8973L8.75387 30.55C8.2016 29.5934 8.52936 28.3703 9.48594 27.818L15.6469 24.261C15.6355 24.2197 15.6244 24.1782 15.6137 24.1366H6.5V22.5811C6.5 21.4765 7.39543 20.5811 8.5 20.5811H15.6137C15.6246 20.5388 15.6358 20.4966 15.6475 20.4546L7.75391 15.8972L8.53169 14.5501C9.08397 13.5935 10.3071 13.2657 11.2637 13.818L17.427 17.3763C17.4573 17.3455 17.4879 17.3148 17.5188 17.2845L12.9609 9.39008L14.3081 8.61231C15.2647 8.06002 16.4879 8.38777 17.0401 9.34436L20.5972 15.5053C20.6388 15.4938 20.6807 15.4826 20.7227 15.4718V6.3584H22.2782ZM25.647 24.0166L25.5129 24.2489C25.2237 24.7087 24.8322 25.0977 24.3703 25.3838L24.1802 25.4935C23.6947 25.7542 23.1416 25.9053 22.554 25.914H22.4475C20.5083 25.8855 18.9452 24.3047 18.9452 22.3588C18.9452 20.3951 20.537 18.8032 22.5008 18.8032C23.1125 18.8032 23.6882 18.9577 24.1909 19.2298L24.3599 19.3274C24.8366 19.6204 25.239 20.0227 25.532 20.4994L25.6299 20.669C25.8909 21.1513 26.0436 21.7007 26.0556 22.2847V22.4329C26.0439 23.0041 25.8975 23.5421 25.647 24.0166Z" fill="currentColor"/>
        </svg>
        <span class="text-[15px] font-semibold tracking-tight">Kovira</span>
      </a>

      <ul class="flex items-center gap-8 justify-self-center max-[768px]:hidden">
        <li><a href="/forms" class={`text-sm font-medium transition-colors duration-200 hover:text-white ${activeTab === 'forms' ? 'text-white font-bold underline underline-offset-4' : 'text-white/70'}`}>Forms</a></li>
        <li><a href="/submissions" class={`text-sm font-medium transition-colors duration-200 hover:text-white ${activeTab === 'submissions' ? 'text-white font-bold underline underline-offset-4' : 'text-white/70'}`}>Submissions</a></li>
        <li><a href="/pricing" class={`text-sm font-medium transition-colors duration-200 hover:text-white ${activeTab === 'pricing' ? 'text-white font-bold underline underline-offset-4' : 'text-white/70'}`}>Pricing</a></li>
        <li><a href="/analytics" class={`text-sm font-medium transition-colors duration-200 hover:text-white ${activeTab === 'analytics' ? 'text-white font-bold underline underline-offset-4' : 'text-white/70'}`}>Analytics</a></li>
      </ul>

      <div class="flex items-center gap-4 justify-self-end">
        <div class="flex items-center gap-4 max-[768px]:hidden">
          <button id="nav-signin-btn" class="open-login-btn text-white/75 text-sm font-medium transition-colors duration-200 hover:text-white bg-transparent border-none cursor-pointer">Sign In</button>
          <button id="nav-getstarted-btn" class="open-login-btn bg-ink text-white px-5 py-2 rounded-buttons text-sm font-medium tracking-[-0.025em] border border-white/15 btn-primary-shadow transition-all duration-200 hover:bg-charcoal hover:-translate-y-[1px] cursor-pointer">Get Started</button>
        </div>
        <button id="mobile-menu-btn" class="hidden max-[768px]:block text-white hover:text-white/80 focus:outline-none cursor-pointer bg-transparent border-none p-1" aria-label="Open Menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 9h16.5m-16.5 6.75h16.5"></path>
          </svg>
        </button>
      </div>
    </nav>

    <div transition:name="hero-glow" transition:animate="none" class="hero-glow"></div>
    
    <svg transition:name="background-arcs" transition:animate="none" class="absolute bottom-[-5%] left-0 w-full h-[65%] pointer-events-none z-2 opacity-50 max-[768px]:hidden" viewBox="0 0 1440 600" fill="none" xmlns="http://www.w3.org/2000/svg">
      <ellipse cx="720" cy="550" rx="700" ry="240" stroke="rgba(255,255,255,0.06)" stroke-width="1" stroke-dasharray="3 6" />
      <ellipse cx="720" cy="550" rx="600" ry="205" stroke="rgba(255,255,255,0.07)" stroke-width="1" stroke-dasharray="3 6" />
      <ellipse cx="720" cy="550" rx="500" ry="170" stroke="rgba(255,255,255,0.08)" stroke-width="1" stroke-dasharray="3 6" />
      <ellipse cx="720" cy="550" rx="400" ry="135" stroke="rgba(255,255,255,0.09)" stroke-width="1" stroke-dasharray="3 6" />
      <ellipse cx="720" cy="550" rx="300" ry="100" stroke="rgba(255,255,255,0.1)" stroke-width="1" stroke-dasharray="3 6" />
      <ellipse cx="720" cy="550" rx="200" ry="65" stroke="rgba(255,255,255,0.12)" stroke-width="1" stroke-dasharray="3 6" />
      <ellipse cx="720" cy="550" rx="100" ry="30" stroke="rgba(255,255,255,0.15)" stroke-width="1" stroke-dasharray="3 6" />
      <path d="M 20 550 Q 720 150 1420 550" stroke="rgba(255,255,255,0.04)" stroke-width="1.5" stroke-dasharray="4 8" />
      <path d="M 120 550 Q 720 250 1320 550" stroke="rgba(255,255,255,0.05)" stroke-width="1.5" stroke-dasharray="4 8" />
      <path d="M 220 550 Q 720 350 1220 550" stroke="rgba(255,255,255,0.06)" stroke-width="1.5" stroke-dasharray="4 8" />
    </svg>

    <main transition:name="main-content" class="flex-1 flex flex-col w-full min-h-0 relative z-5 overflow-hidden pb-14">
      <slot />
    </main>

    <div transition:name="footer" transition:animate="none" class="absolute bottom-0 left-0 right-0 w-full flex flex-col items-center gap-1 pb-4 z-10 pointer-events-none max-[768px]:pb-3">
      <div class="flex flex-col items-center gap-1 pointer-events-auto cursor-default">
        <div class="text-[11px] text-black/60 font-medium tracking-wider text-center">
          <span>© 2026 Kovira. All rights reserved.</span>
          <a href="/help" class="mx-2 transition-colors duration-200 hover:text-black">Help</a>
          <a href="/terms" class="mx-2 transition-colors duration-200 hover:text-black">Terms</a>
          <a href="/privacy" class="mx-2 transition-colors duration-200 hover:text-black">Privacy</a>
          <a href="/billing" class="mx-2 transition-colors duration-200 hover:text-black">Billing</a>
          <span class="mx-1 text-black/20">|</span>
          <a href="/app" class="mx-2 transition-colors duration-200 hover:text-black">Platform</a>
        </div>
        <div class="text-[11px] text-black/60 font-medium tracking-wide text-center">Developed by Kirian with <span class="text-black/80">♥</span></div>
      </div>
    </div>
  </div>

  <div id="mobile-menu-overlay" class="fixed inset-0 bg-[#090a16] z-[60] transform translate-x-full flex flex-col p-6 pointer-events-none">
    <div class="flex items-center justify-between mb-8">
      <a href="/" class="flex items-center gap-2.5 text-white">
        <svg class="h-6 w-auto flex-shrink-0" viewBox="0 0 44 45" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path fill-rule="evenodd" clip-rule="evenodd" d="M22.2782 6.3584C23.3828 6.3584 24.2782 7.25383 24.2782 8.3584V15.4716C24.3202 15.4824 24.3621 15.4936 24.4038 15.5052L28.96 7.61365L30.3071 8.39141C31.2636 8.94371 31.5914 10.1669 31.0391 11.1235L27.4822 17.2841C27.5129 17.3142 27.5433 17.3446 27.5734 17.3752L35.4668 12.818L36.2446 14.1652C36.7969 15.1218 36.4691 16.3449 35.5125 16.8972L29.3536 20.4531C29.3654 20.4956 29.3768 20.5382 29.3878 20.5811H38.5V22.1366C38.5 23.2412 37.6046 24.1366 36.5 24.1366H29.3878C29.377 24.1787 29.3658 24.2207 29.3542 24.2625L37.2446 28.818L36.4668 30.1652C35.9145 31.1218 34.6913 31.4495 33.7347 30.8973L27.5748 27.3409C27.5446 27.3717 27.5141 27.4022 27.4833 27.4324L32.0401 35.325L30.6931 36.1028C29.7365 36.6551 28.5133 36.3273 27.961 35.3708L24.4052 29.212C24.363 29.2237 24.3207 29.235 24.2782 29.2459V38.3584H22.7227C21.6181 38.3584 20.7227 37.463 20.7227 36.3584V29.2458C20.6802 29.2349 20.6379 29.2235 20.5958 29.2119L16.0392 37.1042L14.692 36.3264C13.7354 35.7742 13.4077 34.551 13.96 33.5944L17.5178 27.432C17.4868 27.4016 17.456 27.3708 17.4256 27.3398L9.53168 31.8973L8.75387 30.55C8.2016 29.5934 8.52936 28.3703 9.48594 27.818L15.6469 24.261C15.6355 24.2197 15.6244 24.1782 15.6137 24.1366H6.5V22.5811C6.5 21.4765 7.39543 20.5811 8.5 20.5811H15.6137C15.6246 20.5388 15.6358 20.4966 15.6475 20.4546L7.75391 15.8972L8.53169 14.5501C9.08397 13.5935 10.3071 13.2657 11.2637 13.818L17.427 17.3763C17.4573 17.3455 17.4879 17.3148 17.5188 17.2845L12.9609 9.39008L14.3081 8.61231C15.2647 8.06002 16.4879 8.38777 17.0401 9.34436L20.5972 15.5053C20.6388 15.4938 20.6807 15.4826 20.7227 15.4718V6.3584H22.2782ZM25.647 24.0166L25.5129 24.2489C25.2237 24.7087 24.8322 25.0977 24.3703 25.3838L24.1802 25.4935C23.6947 25.7542 23.1416 25.9053 22.554 25.914H22.4475C20.5083 25.8855 18.9452 24.3047 18.9452 22.3588C18.9452 20.3951 20.537 18.8032 22.5008 18.8032C23.1125 18.8032 23.6882 18.9577 24.1909 19.2298L24.3599 19.3274C24.8366 19.6204 25.239 20.0227 25.532 20.4994L25.6299 20.669C25.8909 21.1513 26.0436 21.7007 26.0556 22.2847V22.4329C26.0439 23.0041 25.8975 23.5421 25.647 24.0166Z" fill="currentColor"/>
        </svg>
        <span class="text-[15px] font-semibold tracking-tight">Kovira</span>
      </a>
      <button id="close-mobile-menu-btn" class="text-white hover:text-white/80 focus:outline-none cursor-pointer bg-transparent border-none p-1">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
    
    <ul class="flex flex-col gap-6 text-lg font-medium text-white/80">
      <li><a href="/forms" class="hover:text-white transition-colors block py-2.5 border-b border-white/10">Forms</a></li>
      <li><a href="/submissions" class="hover:text-white transition-colors block py-2.5 border-b border-white/10">Submissions</a></li>
      <li><a href="/pricing" class="hover:text-white transition-colors block py-2.5 border-b border-white/10">Pricing</a></li>
      <li><a href="/analytics" class="hover:text-white transition-colors block py-2.5 border-b border-white/10">Analytics</a></li>
      <li><a href="/billing" class="hover:text-white transition-colors block py-2.5 border-b border-white/10">Billing</a></li>
    </ul>

    <div class="mt-auto flex flex-col gap-4 pb-8">
      <button class="open-login-btn w-full text-center text-white/70 py-3 rounded-buttons text-sm font-medium border border-white/10 cursor-pointer bg-transparent">Sign In</button>
      <button class="open-login-btn w-full text-center bg-ink text-white py-3 rounded-buttons text-sm font-medium border border-white/15 cursor-pointer">Get Started</button>
    </div>
  </div>

  <div id="login-view" transition:persist="login-view" transition:name="login-view" transition:animate="none" class="fixed inset-0 w-full h-dvh overflow-hidden z-50 pointer-events-none">
    <div class="grid grid-cols-1 md:grid-cols-2 h-full w-full">
      
      <div id="login-left" class="hidden md:block h-full w-full bg-hero-pattern bg-cover bg-center relative">
        <div class="absolute inset-0 bg-black/10"></div>
        <div class="hero-glow"></div>
        <div class="absolute inset-0 bg-gradient-to-r from-transparent to-[#090a16]/20"></div>
      </div>

      <div id="login-right" class="bg-white h-full w-full flex flex-col justify-between p-12 max-[768px]:px-6 max-[768px]:py-8 text-ink relative overflow-y-auto">
        
        <div class="relative w-full flex items-center justify-center min-h-[44px] max-[768px]:min-h-[40px]">
          <button id="close-login-btn" class="absolute left-0 flex items-center justify-center cursor-pointer text-ash hover:text-ink transition-colors duration-150 bg-transparent border-none p-1" aria-label="Go Back">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"></path></svg>
          </button>
          
          <a href="/" class="flex items-center gap-2.5 text-ink hover:opacity-90 transition-opacity cursor-pointer">
            <svg class="h-6 w-auto flex-shrink-0" viewBox="0 0 44 45" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M22.2782 6.3584C23.3828 6.3584 24.2782 7.25383 24.2782 8.3584V15.4716C24.3202 15.4824 24.3621 15.4936 24.4038 15.5052L28.96 7.61365L30.3071 8.39141C31.2636 8.94371 31.5914 10.1669 31.0391 11.1235L27.4822 17.2841C27.5129 17.3142 27.5433 17.3446 27.5734 17.3752L35.4668 12.818L36.2446 14.1652C36.7969 15.1218 36.4691 16.3449 35.5125 16.8972L29.3536 20.4531C29.3654 20.4956 29.3768 20.5382 29.3878 20.5811H38.5V22.1366C38.5 23.2412 37.6046 24.1366 36.5 24.1366H29.3878C29.377 24.1787 29.3658 24.2207 29.3542 24.2625L37.2446 28.818L36.4668 30.1652C35.9145 31.1218 34.6913 31.4495 33.7347 30.8973L27.5748 27.3409C27.5446 27.3717 27.5141 27.4022 27.4833 27.4324L32.0401 35.325L30.6931 36.1028C29.7365 36.6551 28.5133 36.3273 27.961 35.3708L24.4052 29.212C24.363 29.2237 24.3207 29.235 24.2782 29.2459V38.3584H22.7227C21.6181 38.3584 20.7227 37.463 20.7227 36.3584V29.2458C20.6802 29.2349 20.6379 29.2235 20.5958 29.2119L16.0392 37.1042L14.692 36.3264C13.7354 35.7742 13.4077 34.551 13.96 33.5944L17.5178 27.432C17.4868 27.4016 17.456 27.3708 17.4256 27.3398L9.53168 31.8973L8.75387 30.55C8.2016 29.5934 8.52936 28.3703 9.48594 27.818L15.6469 24.261C15.6355 24.2197 15.6244 24.1782 15.6137 24.1366H6.5V22.5811C6.5 21.4765 7.39543 20.5811 8.5 20.5811H15.6137C15.6246 20.5388 15.6358 20.4966 15.6475 20.4546L7.75391 15.8972L8.53169 14.5501C9.08397 13.5935 10.3071 13.2657 11.2637 13.818L17.427 17.3763C17.4573 17.3455 17.4879 17.3148 17.5188 17.2845L12.9609 9.39008L14.3081 8.61231C15.2647 8.06002 16.4879 8.38777 17.0401 9.34436L20.5972 15.5053C20.6388 15.4938 20.6807 15.4826 20.7227 15.4718V6.3584H22.2782ZM25.647 24.0166L25.5129 24.2489C25.2237 24.7087 24.8322 25.0977 24.3703 25.3838L24.1802 25.4935C23.6947 25.7542 23.1416 25.9053 22.554 25.914H22.4475C20.5083 25.8855 18.9452 24.3047 18.9452 22.3588C18.9452 20.3951 20.537 18.8032 22.5008 18.8032C23.1125 18.8032 23.6882 18.9577 24.1909 19.2298L24.3599 19.3274C24.8366 19.6204 25.239 20.0227 25.532 20.4994L25.6299 20.669C25.8909 21.1513 26.0436 21.7007 26.0556 22.2847V22.4329C26.0439 23.0041 25.8975 23.5421 25.647 24.0166Z" fill="currentColor"/>
            </svg>
            <span class="text-[15px] font-semibold tracking-tight">Kovira</span>
          </a>
        </div>

        <div class="max-w-[360px] w-full mx-auto my-auto flex flex-col gap-6 max-[768px]:my-4">
          
          <div id="auth-slider">
            
            <div id="auth-signup-view" class="auth-view-panel auth-view-active flex flex-col gap-6">
              <div class="flex flex-col gap-2 text-center">
                <h2 class="text-2xl font-bold tracking-tight text-ink">Create an account</h2>
                <p class="text-sm text-ash">Enter your email to create your Kovira account</p>
              </div>
              
              <form class="auth-email-form flex flex-col gap-3">
                <input type="email" required placeholder="Enter your email" class="w-full border border-soft-mist rounded-buttons px-4 py-3 text-sm focus:outline-none focus:border-ink placeholder-ash/50 text-ink bg-[#fbfbfb] font-sans" />
                <button type="submit" class="w-full bg-ink text-white py-3 rounded-buttons text-sm font-semibold tracking-[-0.025em] border border-transparent shadow-md transition-all duration-200 hover:bg-charcoal cursor-pointer">Submit</button>
              </form>

              <p class="text-xs text-ash text-center leading-normal">
                Already have an account? 
                <button class="switch-auth-state text-ink font-semibold underline hover:text-ink/80 bg-transparent border-none p-0 cursor-pointer">Login</button>
              </p>
            </div>

            <div id="auth-login-view" class="auth-view-panel auth-view-right-exit flex flex-col gap-6">
              <div class="flex flex-col gap-2 text-center">
                <h2 class="text-2xl font-bold tracking-tight text-ink">Sign in to your account</h2>
                <p class="text-sm text-ash">Enter your email to access your workspaces</p>
              </div>
              
              <form class="auth-email-form flex flex-col gap-3">
                <input type="email" required placeholder="Enter your email" class="w-full border border-soft-mist rounded-buttons px-4 py-3 text-sm focus:outline-none focus:border-ink placeholder-ash/50 text-ink bg-[#fbfbfb] font-sans" />
                <button type="submit" class="w-full bg-ink text-white py-3 rounded-buttons text-sm font-semibold tracking-[-0.025em] border border-transparent shadow-md transition-all duration-200 hover:bg-charcoal cursor-pointer">Continue</button>
              </form>

              <p class="text-xs text-ash text-center leading-normal">
                Don't have an account? 
                <button class="switch-auth-state text-ink font-semibold underline hover:text-ink/80 bg-transparent border-none p-0 cursor-pointer">Sign up</button>
              </p>
            </div>

          </div>

          <div class="flex items-center gap-3 w-full">
            <div class="flex-1 h-[1px] bg-soft-mist"></div>
            <span class="text-[10px] font-bold text-ash tracking-widest uppercase">OR</span>
            <div class="flex-1 h-[1px] bg-soft-mist"></div>
          </div>

          <div class="flex flex-col gap-2.5">
            <button class="social-auth-btn flex items-center justify-center gap-2 w-full bg-transparent border border-soft-mist rounded-buttons py-3 px-4 text-sm font-semibold text-ink transition-colors duration-150 hover:bg-[#fbfbfb] cursor-pointer">
              <span>Sign in with</span>
              <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24">
                <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" />
                <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
                <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l2.85-2.22.81-.63z" />
                <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.84c.87-2.6 3.3-4.52 6.16-4.52z" />
              </svg>
            </button>
            <button class="social-auth-btn flex items-center justify-center gap-2 w-full bg-transparent border border-soft-mist rounded-buttons py-3 px-4 text-sm font-semibold text-ink transition-colors duration-150 hover:bg-[#fbfbfb] cursor-pointer">
              <span>Sign in with</span>
              <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="#24292e">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
            </button>
            <button class="social-auth-btn flex items-center justify-center gap-2 w-full bg-transparent border border-soft-mist rounded-buttons py-3 px-4 text-sm font-semibold text-ink transition-colors duration-150 hover:bg-[#fbfbfb] cursor-pointer">
              <span>Sign in with</span>
              <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="#0077b5">
                <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.779-1.75-1.75s.784-1.75 1.75-1.75 1.75.779 1.75 1.75-.784 1.75-1.75 1.75zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
              </svg>
            </button>
          </div>

        </div>

        <div id="auth-loading-overlay" class="absolute inset-0 bg-white z-20 flex flex-col items-center justify-center gap-4 hidden transition-opacity duration-300">
          <div class="w-8 h-8 border-2 border-soft-mist border-t-ink rounded-full animate-spin-custom"></div>
          <div id="loading-text" class="text-sm font-semibold text-ink">Signing you in...</div>
        </div>

        <div class="flex justify-center gap-4 text-[11px] text-ash/50 select-none">
          <a href="/help" class="hover:text-ink">Help</a>
          <span>/</span>
          <a href="/terms" class="hover:text-ink">Terms</a>
          <span>/</span>
          <a href="/privacy" class="hover:text-ink">Privacy</a>
        </div>

      </div>

    </div>
  </div>

  <script>
    import SplitType from 'split-type';
    import { animate, stagger } from 'motion';

    const globalWindow = window as any;
    if (!globalWindow.koviraInitialized) {
      globalWindow.koviraInitialized = true;

      const triggerLoadingRedirect = (actionText: string) => {
        const loadingOverlay = document.getElementById('auth-loading-overlay');
        const loadingText = document.getElementById('loading-text');
        if (loadingText) loadingText.textContent = actionText;
        if (loadingOverlay) loadingOverlay.classList.remove('hidden');
        setTimeout(() => {
          window.location.href = '/app';
        }, 1400);
      };

      const selectSignUpForm = () => {
        const signupView = document.getElementById('auth-signup-view');
        const loginView = document.getElementById('auth-login-view');
        if (signupView && loginView) {
          signupView.classList.remove('auth-view-left-exit');
          signupView.classList.add('auth-view-active');
          loginView.classList.remove('auth-view-active');
          loginView.classList.add('auth-view-right-exit');
        }
      };

      const selectLoginForm = () => {
        const signupView = document.getElementById('auth-signup-view');
        const loginView = document.getElementById('auth-login-view');
        if (signupView && loginView) {
          signupView.classList.remove('auth-view-active');
          signupView.classList.add('auth-view-left-exit');
          loginView.classList.remove('auth-view-right-exit');
          loginView.classList.add('auth-view-active');
        }
      };

      document.addEventListener('click', (e) => {
        const target = e.target;
        if (!(target instanceof Element)) return;

        const tabBtn = target.closest('.tab-btn');
        if (tabBtn) {
          const tabs = document.querySelectorAll('.tab-btn');
          const contents = document.querySelectorAll('.tab-content');
          tabs.forEach(t => {
            t.classList.remove('bg-white', 'text-ink', 'font-semibold');
            t.classList.add('text-white/70', 'font-medium');
          });
          tabBtn.classList.add('bg-white', 'text-ink', 'font-semibold');
          tabBtn.classList.remove('text-white/70', 'font-medium');

          contents.forEach(c => c.classList.add('hidden'));
          const tabName = tabBtn.getAttribute('data-tab');
          const contentEl = document.getElementById(`tab-content-${tabName}`);
          if (contentEl) contentEl.classList.remove('hidden');
          return;
        }

        const openLoginBtn = target.closest('.open-login-btn');
        if (openLoginBtn) {
          e.stopPropagation();
          const id = openLoginBtn.id;
          const text = openLoginBtn.textContent ? openLoginBtn.textContent.trim().toLowerCase() : '';

          // If the mobile menu overlay is open, close it so it doesn't cover the login modal
          const menu = document.getElementById('mobile-menu-overlay');
          if (menu && menu.classList.contains('translate-x-0')) {
            menu.classList.remove('translate-x-0', 'pointer-events-auto');
            menu.classList.add('translate-x-full', 'pointer-events-none');
            document.body.classList.remove('mobile-menu-active');
          }

          if (id === 'nav-signin-btn') {
            selectLoginForm();
          } else if (id === 'nav-getstarted-btn') {
            selectSignUpForm();
          } else {
            if (text.includes('started') || text.includes('build')) {
              selectSignUpForm();
            } else {
              selectLoginForm();
            }
          }
          document.body.classList.add('login-active');
          return;
        }

        const openMenuBtn = target.closest('#mobile-menu-btn');
        if (openMenuBtn) {
          const menu = document.getElementById('mobile-menu-overlay');
          if (menu) {
            menu.classList.remove('translate-x-full', 'pointer-events-none');
            menu.classList.add('translate-x-0', 'pointer-events-auto');
            document.body.classList.add('mobile-menu-active');
          }
          return;
        }

        const closeMenuBtn = target.closest('#close-mobile-menu-btn');
        const isOverlayInteractive = target.closest('#mobile-menu-overlay a, #mobile-menu-overlay button');
        if (closeMenuBtn || isOverlayInteractive) {
          const menu = document.getElementById('mobile-menu-overlay');
          if (menu) {
            menu.classList.remove('translate-x-0', 'pointer-events-auto');
            menu.classList.add('translate-x-full', 'pointer-events-none');
            document.body.classList.remove('mobile-menu-active');
          }
          if (isOverlayInteractive && target.closest('.open-login-btn')) {
            // Allow event to continue propagating so it triggers the open-login-btn handler
          } else {
            return;
          }
        }

        const closeBtn = target.closest('#close-login-btn');
        if (closeBtn) {
          document.body.classList.remove('login-active');
          return;
        }

        const switchBtn = target.closest('.switch-auth-state');
        if (switchBtn) {
          const signupView = document.getElementById('auth-signup-view');
          if (signupView && signupView.classList.contains('auth-view-active')) {
            selectLoginForm();
          } else {
            selectSignUpForm();
          }
          return;
        }

        const socialBtn = target.closest('.social-auth-btn');
        if (socialBtn) {
          const span = socialBtn.querySelector('span');
          const platform = span ? span.textContent : 'social provider';
          triggerLoadingRedirect(`Connecting to ${platform.split('with ')[1] || platform}...`);
          return;
        }
      });

      document.addEventListener('submit', (e) => {
        const target = e.target;
        if (!(target instanceof Element)) return;
        const emailForm = target.closest('.auth-email-form');
        if (emailForm) {
          e.preventDefault();
          triggerLoadingRedirect('Signing you in...');
        }
      });
    }

    const runTextReveal = () => {
      const targets = document.querySelectorAll('.reveal-text');
      targets.forEach(target => {
        (target as HTMLElement).style.opacity = '1';
        const split = new SplitType(target as HTMLElement, { types: 'lines,words' });
        if (split.words && split.words.length > 0) {
          split.words.forEach(word => {
            word.style.display = 'inline-block';
            word.style.position = 'relative';
            word.style.opacity = '0';
            word.style.transform = 'translateX(-24px)';
          });
          animate(
            split.words,
            { opacity: [0, 1], x: [-24, 0] },
            { 
              duration: 0.48, 
              delay: stagger(0.055), 
              easing: [0.16, 1, 0.3, 1] 
            }
          );
        }
      });

      const fadeElements = document.querySelectorAll('.animate-fade-in');
      if (fadeElements.length > 0) {
        fadeElements.forEach(el => {
          (el as HTMLElement).style.opacity = '0';
          (el as HTMLElement).style.transform = 'translateX(-16px)';
        });
        animate(
          fadeElements,
          { opacity: [0, 1], x: [-16, 0] },
          { 
            duration: 0.42, 
            delay: stagger(0.06, { startDelay: 0.12 }), 
            easing: [0.16, 1, 0.3, 1] 
          }
        );
      }
    };

    document.addEventListener('astro:page-load', () => {
      runTextReveal();
    });
  </script>

</body>
</html>
